<ui:FluentWindow x:Class="DailyPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:DailyPlanner.Views"
        xmlns:conv="clr-namespace:DailyPlanner.Converters"
        xmlns:svc="clr-namespace:DailyPlanner.Services"
        Title="Daily &amp; Financial Planner"
        Width="1480" Height="920"
        MinWidth="1200" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <conv:BoolToVisibilityConverter x:Key="VisConv"/>
        <conv:InvertedBoolToVisibilityConverter x:Key="InvVisConv"/>
        <conv:MonthIsSelectedConverter x:Key="MonthSelConv"/>
        <conv:BoolToPlayPauseConverter x:Key="PomodoroButtonConv"/>
    </ui:FluentWindow.Resources>

    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="Left" Modifiers="Ctrl" Command="{Binding PreviousMonthCommand}"/>
        <KeyBinding Key="Right" Modifiers="Ctrl" Command="{Binding NextMonthCommand}"/>
        <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding GoToTodayCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding ToggleSearchCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding ExportToExcelCommand}"/>
        <KeyBinding Key="P" Modifiers="Ctrl" Command="{Binding TogglePomodoroCommand}"/>
        <KeyBinding Key="M" Modifiers="Ctrl" Command="{Binding ToggleFinanceCommand}"/>
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,1,0">
            <Border.Background>
                <DynamicResourceExtension ResourceKey="SidebarBgBrush"/>
            </Border.Background>
            <DockPanel>
                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Margin="20,48,20,8">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="22" Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"/>
                        <TextBlock FontSize="18" FontWeight="Bold" FontFamily="{StaticResource MainFont}">
                            <Run Text="Daily" Foreground="{DynamicResource AccentBrush}"/>
                            <Run Text="Planner" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="{Binding SelectedYear}" FontSize="11"
                               Foreground="{DynamicResource MutedBrush}" Margin="32,3,0,0"/>
                </StackPanel>

                <!-- Today Mini Widget -->
                <Border DockPanel.Dock="Bottom" Margin="12,0,12,8" CornerRadius="8" Padding="10,8">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.06"/>
                    </Border.Background>
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <ui:SymbolIcon Symbol="CalendarToday24" FontSize="12"
                                           Foreground="{DynamicResource AccentBrush}" DockPanel.Dock="Left" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding [Today], Source={x:Static svc:Loc.Instance}}" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TodayProgress}" FontSize="9"
                                       Foreground="{DynamicResource MutedBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock Text="{Binding TodayTasks}" FontSize="10"
                                   TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}"
                                   LineHeight="16" MaxHeight="90"/>
                    </StackPanel>
                </Border>

                <!-- Daily Quote -->
                <Border DockPanel.Dock="Bottom" Margin="12,0,12,12" CornerRadius="8" Padding="10,8"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <TextBlock Text="{Binding DailyQuote}" FontSize="10" FontStyle="Italic"
                               TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}"
                               LineHeight="15"/>
                </Border>

                <!-- Bottom buttons -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,16">
                    <ui:Button Content="Pomodoro" Icon="{ui:SymbolIcon Timer24}"
                               HorizontalAlignment="Stretch"
                               Command="{Binding TogglePomodoroCommand}" Margin="0,0,0,4"
                               ToolTip="Ctrl+P">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPomodoroOpen}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="0,0,2,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <ui:Button Content="{Binding [Statistics], Source={x:Static svc:Loc.Instance}}" Icon="{ui:SymbolIcon DataBarVertical24}"
                               HorizontalAlignment="Stretch"
                               Click="Statistics_Click" Margin="0,0,0,4">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStatisticsOpen}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="0,0,2,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <ui:Button Content="{Binding [Finance], Source={x:Static svc:Loc.Instance}}" Icon="{ui:SymbolIcon Money24}"
                               HorizontalAlignment="Stretch"
                               Click="Finance_Click" Margin="0,0,0,4"
                               ToolTip="{Binding [FinanceTooltip], Source={x:Static svc:Loc.Instance}}">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFinanceOpen}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="0,0,2,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <ui:Button Content="{Binding [Export], Source={x:Static svc:Loc.Instance}}" Icon="{ui:SymbolIcon ArrowDownload24}"
                               Appearance="Transparent" HorizontalAlignment="Stretch"
                               Command="{Binding ExportToExcelCommand}" Margin="0,0,0,4"/>
                    <ui:Button Content="{Binding [TodayBtn], Source={x:Static svc:Loc.Instance}}" Icon="{ui:SymbolIcon CalendarToday24}"
                               Appearance="Transparent" HorizontalAlignment="Stretch"
                               Command="{Binding GoToTodayCommand}" Margin="0,0,0,4"/>
                    <ui:Button Content="{Binding [Settings], Source={x:Static svc:Loc.Instance}}" Icon="{ui:SymbolIcon Settings24}"
                               HorizontalAlignment="Stretch"
                               Click="Settings_Click">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="0,0,2,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                </StackPanel>

                <!-- Month List -->
                <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="0,12,0,8">
                    <ItemsControl ItemsSource="{Binding Months}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="MonthBorder" CornerRadius="8" Margin="6,1" Cursor="Hand"
                                        Background="Transparent" MouseLeftButtonDown="MonthBorder_Click"
                                        Tag="{Binding Number}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource MonthSelConv}">
                                                            <Binding Path="Number"/>
                                                            <Binding Path="DataContext.SelectedMonth"
                                                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Background" Value="{DynamicResource MonthHoverBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="BorderThickness" Value="0,0,2,0"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource MonthPressedBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Name}" Padding="14,8"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontFamily="{StaticResource MainFont}" FontSize="13"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <DockPanel Grid.Column="1" Background="{DynamicResource PageBgBrush}">
            <!-- Title Bar -->
            <ui:TitleBar DockPanel.Dock="Top" Title="" ShowMaximize="True" ShowMinimize="True"/>

            <!-- Search Bar (collapsible) -->
            <Border DockPanel.Dock="Top" Padding="24,0,24,0"
                    Visibility="{Binding IsSearchOpen, Converter={StaticResource VisConv}}">
                <Border CornerRadius="10" Padding="12,8" Margin="0,0,0,8"
                        Background="{DynamicResource CardBg}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <DockPanel>
                        <ui:SymbolIcon Symbol="Search24" FontSize="16"
                                       Foreground="{DynamicResource MutedBrush}"
                                       DockPanel.Dock="Left" Margin="0,0,10,0"/>
                        <TextBox Style="{StaticResource SearchTextBox}"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent"
                                 FontSize="14" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>
            </Border>

            <!-- Search Results -->
            <Border DockPanel.Dock="Top" MaxHeight="200" Margin="24,0,24,8"
                    Visibility="{Binding IsSearchOpen, Converter={StaticResource VisConv}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SearchResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" Margin="0,1" CornerRadius="6" Cursor="Hand"
                                        Background="{DynamicResource CardBg}"
                                        MouseLeftButtonDown="SearchResult_Click"
                                        Tag="{Binding}">
                                    <DockPanel>
                                        <ui:SymbolIcon Symbol="TaskListLtr24" FontSize="12"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       DockPanel.Dock="Left" Margin="0,0,8,0"/>
                                        <TextBlock DockPanel.Dock="Right" FontSize="10"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Run Text="{Binding Context, Mode=OneWay}"/>
                                            <Run Text=" | "/>
                                            <Run Text="{Binding Week, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Text}" FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Top Navigation -->
            <Border DockPanel.Dock="Top" Padding="24,4,24,12"
                    Visibility="{Binding IsMainNavVisible, Converter={StaticResource VisConv}}">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <ui:Button Icon="{ui:SymbolIcon ChevronLeft24}" Appearance="Transparent"
                                   Command="{Binding PreviousMonthCommand}" Padding="8"/>
                        <TextBlock FontSize="24" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource MainFont}"
                                   VerticalAlignment="Center" Margin="12,0">
                            <Run Text="{Binding SelectedMonthName, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding SelectedYear}" FontSize="24" FontWeight="Light"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontFamily="{StaticResource MainFont}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ui:Button Icon="{ui:SymbolIcon ChevronRight24}" Appearance="Transparent"
                                   Command="{Binding NextMonthCommand}" Padding="8"/>

                        <!-- Search toggle -->
                        <ui:Button Icon="{ui:SymbolIcon Search24}" Appearance="Transparent"
                                   Command="{Binding ToggleSearchCommand}" Padding="8" Margin="8,0,0,0"
                                   ToolTip="{Binding [SearchTooltip], Source={x:Static svc:Loc.Instance}}"/>
                        <!-- Copy week -->
                        <ui:Button Icon="{ui:SymbolIcon Copy24}" Appearance="Transparent"
                                   Command="{Binding CopyPreviousWeekCommand}" Padding="8" Margin="4,0,0,0"
                                   ToolTip="{Binding [CopyWeekTooltip], Source={x:Static svc:Loc.Instance}}"/>
                    </StackPanel>

                    <!-- Week Tabs -->
                    <Border DockPanel.Dock="Right" HorizontalAlignment="Right" CornerRadius="10" Padding="4,3"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <ItemsControl ItemsSource="{Binding Weeks}" VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton GroupName="Weeks" Margin="2,0" Padding="12,7"
                                                 IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                 Checked="WeekTab_Checked" Tag="{Binding}"
                                                 Content="{Binding WeekRange}">
                                        <RadioButton.Template>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="Bd" CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}"
                                                        Background="Transparent" Cursor="Hand">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Bd" Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                                                    <GradientStop Color="{DynamicResource AccentDarkColor}" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </RadioButton.Template>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Page Content -->
            <Grid>
                <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden">
                    <Frame.RenderTransform>
                        <TranslateTransform/>
                    </Frame.RenderTransform>
                </Frame>

                <!-- Loading overlay -->
                <Border Background="#80000000" CornerRadius="8"
                        Visibility="{Binding IsLoading, Converter={StaticResource VisConv}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="24,16">
                    <StackPanel Orientation="Horizontal">
                        <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20"/>
                        <TextBlock Text="{Binding [Loading], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="13" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>

        <!-- Pomodoro Floating Panel -->
        <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,24,24" CornerRadius="16" Padding="20,16"
                Visibility="{Binding IsPomodoroOpen, Converter={StaticResource VisConv}}"
                Panel.ZIndex="100"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="30" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>
            <StackPanel DataContext="{Binding Pomodoro}" Width="280">
                <TextBlock Text="{Binding ModeLabel}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding PhaseLabel}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding TimeDisplay}" FontSize="42" FontWeight="Bold"
                           HorizontalAlignment="Center" FontFamily="Cascadia Code, Consolas"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100" Height="3" Margin="0,8,0,8"
                             Style="{StaticResource DayProgressBar}"/>

                <!-- Timer Settings -->
                <Grid Margin="0,0,0,8" Visibility="{Binding IsRunning, Converter={StaticResource InvVisConv}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding [PomWork], Source={x:Static svc:Loc.Instance}}" FontSize="9" HorizontalAlignment="Center"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,4"/>
                    <TextBlock Grid.Column="2" Text="{Binding [PomBreak], Source={x:Static svc:Loc.Instance}}" FontSize="9" HorizontalAlignment="Center"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,4"/>
                    <TextBlock Grid.Column="4" Text="{Binding [PomFocus], Source={x:Static svc:Loc.Instance}}" FontSize="9" HorizontalAlignment="Center"
                               Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,4"/>
                    <ui:NumberBox Grid.Row="1" Grid.Column="0" Value="{Binding WorkMinutes, Mode=TwoWay}"
                                  Minimum="1" Maximum="120" SpinButtonPlacementMode="Hidden"
                                  Height="32" FontSize="14" HorizontalContentAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="/" VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource MutedBrush}" FontSize="14"/>
                    <ui:NumberBox Grid.Row="1" Grid.Column="2" Value="{Binding BreakMinutes, Mode=TwoWay}"
                                  Minimum="1" Maximum="60" SpinButtonPlacementMode="Hidden"
                                  Height="32" FontSize="14" HorizontalContentAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="/" VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource MutedBrush}" FontSize="14"/>
                    <ui:NumberBox Grid.Row="1" Grid.Column="4" Value="{Binding FocusAlertMinutes, Mode=TwoWay}"
                                  Minimum="1" Maximum="180" SpinButtonPlacementMode="Hidden"
                                  Height="32" FontSize="14" HorizontalContentAlignment="Center"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ui:Button Appearance="Primary" Padding="12,6"
                               Command="{Binding ToggleTimerCommand}" Margin="0,0,6,0"
                               Content="{Binding IsRunning, Converter={StaticResource PomodoroButtonConv}}">
                    </ui:Button>
                    <ui:Button Icon="{ui:SymbolIcon ArrowReset24}" Appearance="Transparent" Padding="8,6"
                               Command="{Binding ResetTimerCommand}" Margin="0,0,6,0"
                               ToolTip="{Binding [PomReset], Source={x:Static svc:Loc.Instance}}"/>
                    <ui:Button Icon="{ui:SymbolIcon Next24}" Appearance="Transparent" Padding="8,6"
                               Command="{Binding SkipPhaseCommand}" Margin="0,0,6,0"
                               ToolTip="{Binding [PomSkip], Source={x:Static svc:Loc.Instance}}"/>
                    <ui:Button Appearance="Transparent" Padding="8,6"
                               Command="{Binding ToggleFocusModeCommand}"
                               ToolTip="{Binding [PomToggleFocus], Source={x:Static svc:Loc.Instance}}" Content="F"
                               FontWeight="Bold" FontSize="12"/>
                </StackPanel>
                <TextBlock Margin="0,8,0,0" HorizontalAlignment="Center" FontSize="11"
                           Foreground="{DynamicResource MutedBrush}">
                    <Run Text="{Binding [PomSessions], Source={x:Static svc:Loc.Instance}, Mode=OneWay}"/><Run Text="{Binding SessionsCompleted, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>
        </Border>

    </Grid>
</ui:FluentWindow>
