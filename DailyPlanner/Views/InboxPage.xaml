<Page x:Class="DailyPlanner.Views.InboxPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:svc="clr-namespace:DailyPlanner.Services"
      xmlns:vm="clr-namespace:DailyPlanner.ViewModels"
      xmlns:conv="clr-namespace:DailyPlanner.Converters"
      Foreground="{DynamicResource TextPrimaryBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="VisConv"/>
        <conv:InvertedBoolToVisibilityConverter x:Key="InvVisConv"/>
        <conv:NullableDateOnlyToDateTimeConverter x:Key="NullableDateOnlyConverter"/>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding [InboxTitle], Source={x:Static svc:Loc.Instance}}"
                       FontSize="26" FontWeight="SemiBold" DockPanel.Dock="Left"
                       FontFamily="{StaticResource MainFont}"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Icon="{ui:SymbolIcon Add24}"
                           Content="{Binding [AddTask], Source={x:Static svc:Loc.Instance}}"
                           Command="{Binding AddManualCommand}"
                           Appearance="Secondary" Margin="0,0,8,0"/>
                <ui:Button Icon="{ui:SymbolIcon ArrowSync24}"
                           Content="{Binding [SyncTrello], Source={x:Static svc:Loc.Instance}}"
                           Command="{Binding SyncTrelloCommand}"
                           Appearance="Primary"/>
            </StackPanel>
        </DockPanel>

        <!-- Status bar -->
        <Border Grid.Row="1" Margin="0,0,0,12" Padding="12,8"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="6"
                Visibility="{Binding StatusMessage, Converter={StaticResource VisConv}}">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>

        <!-- Kanban: Inbox + 7 days (scrolls horizontally on narrow windows) -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <Grid MinWidth="900">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Inbox column -->
            <Border Grid.Column="0"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="8" Padding="12"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding [InboxTitle], Source={x:Static svc:Loc.Instance}}"
                               FontSize="14" FontWeight="SemiBold" Margin="4,0,0,10"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <Grid Grid.Row="1">
                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding HasTasks, Converter={StaticResource InvVisConv}}">
                            <ui:SymbolIcon Symbol="MailInbox24" FontSize="40"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding [InboxEmpty], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding [InboxEmptyHint], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding HasTasks, Converter={StaticResource VisConv}}">
                            <ItemsControl ItemsSource="{Binding Tasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:InboxTaskViewModel}">
                                        <Border Margin="0,0,0,10" Padding="0"
                                                Background="{DynamicResource CardBg}"
                                                CornerRadius="10"
                                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                                BorderThickness="1"
                                                Tag="{Binding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Drag handle -->
                                                <Border Grid.Column="0" Width="22" Background="Transparent"
                                                        Cursor="SizeAll"
                                                        ToolTip="Drag to move to a day"
                                                        PreviewMouseLeftButtonDown="InboxItem_MouseDown"
                                                        MouseMove="InboxItem_MouseMove"
                                                        Tag="{Binding}">
                                                    <TextBlock Text="⋮⋮" FontSize="14" FontWeight="Bold"
                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="0,10,10,10">
                                                    <TextBox Text="{Binding Text, UpdateSourceTrigger=LostFocus}"
                                                             LostFocus="InboxText_LostFocus"
                                                             BorderThickness="0" Background="Transparent"
                                                             FontSize="13"
                                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                                             TextWrapping="Wrap"/>
                                                    <DockPanel Margin="0,6,0,0">
                                                        <TextBlock DockPanel.Dock="Left" Text="{Binding SourceLabel}" FontSize="10"
                                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding DueDateDisplay}" FontSize="10"
                                                                   Foreground="{DynamicResource WarningBrush}" Margin="6,0,0,0"
                                                                   Visibility="{Binding HasDueDate, Converter={StaticResource VisConv}}"/>
                                                    </DockPanel>
                                                    <DockPanel Margin="0,8,0,0">
                                                        <ui:Button DockPanel.Dock="Right"
                                                                   Content="{Binding [MoveToDay], Source={x:Static svc:Loc.Instance}}"
                                                                   FontSize="11" Padding="8,3" Appearance="Primary"
                                                                   Click="MoveToDay_Click" Tag="{Binding}"/>
                                                        <DatePicker SelectedDate="{Binding DueDate, Converter={StaticResource NullableDateOnlyConverter}, Mode=TwoWay}"
                                                                    Margin="0,0,8,0" FontSize="11"
                                                                    LostFocus="InboxText_LostFocus"/>
                                                    </DockPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- Week days -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Week nav -->
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <ui:Button DockPanel.Dock="Left" Icon="{ui:SymbolIcon ChevronLeft24}"
                               Appearance="Transparent" Command="{Binding ShiftWeekCommand}" CommandParameter="-1"/>
                    <ui:Button DockPanel.Dock="Right" Icon="{ui:SymbolIcon ChevronRight24}"
                               Appearance="Transparent" Command="{Binding ShiftWeekCommand}" CommandParameter="1"
                               HorizontalAlignment="Right"/>
                </DockPanel>

                <!-- Day columns -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Days}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:InboxDayViewModel}">
                            <Border Margin="4,0" Padding="10" MinHeight="200"
                                    Background="{DynamicResource CardBg}"
                                    CornerRadius="14"
                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                    BorderThickness="1"
                                    AllowDrop="True"
                                    DragEnter="DayColumn_DragEnter"
                                    DragLeave="DayColumn_DragLeave"
                                    DragOver="DayColumn_DragOver"
                                    Drop="DayColumn_Drop"
                                    Tag="{Binding}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource FocusBgBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#8B5CF6" BlurRadius="24" ShadowDepth="0" Opacity="0.45"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding DayName}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding DateLabel}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,2,0,16"/>
                                    <TextBlock Text="⇣" FontSize="22"
                                               Foreground="{DynamicResource AccentBrush}"
                                               HorizontalAlignment="Center" Opacity="0.6"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
        </ScrollViewer>
    </Grid>
</Page>
