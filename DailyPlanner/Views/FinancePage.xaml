<Page x:Class="DailyPlanner.Views.FinancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:conv="clr-namespace:DailyPlanner.Converters"
      xmlns:svc="clr-namespace:DailyPlanner.Services"
      Foreground="{DynamicResource TextPrimaryBrush}">

    <Page.Resources>
        <conv:FinanceTypeToBrushConverter x:Key="TypeBrushConv"/>
        <conv:BudgetProgressToBrushConverter x:Key="BudgetBrushConv"/>
        <conv:DecimalToCurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="VisConv"/>
        <conv:InvertedBoolToVisibilityConverter x:Key="InvVisConv"/>

        <!-- Tab toggle button style -->
        <Style x:Key="FinanceTabButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{DynamicResource MainFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="Transparent"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleBgBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Inline editable textbox for finance -->
        <Style x:Key="FinanceInlineTextBox" TargetType="TextBox" BasedOn="{StaticResource TaskTextBox}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="MinHeight" Value="22"/>
        </Style>

        <Style x:Key="FinanceAmountTextBox" TargetType="TextBox" BasedOn="{StaticResource TaskTextBox}">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>

        <!-- Compact DatePicker style -->
        <Style x:Key="CompactDatePicker" TargetType="DatePicker">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,0,24,24" MaxWidth="960" HorizontalAlignment="Left">

            <!-- Header with month navigation + export + import -->
            <DockPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ui:Button Icon="{ui:SymbolIcon ChevronLeft24}" Appearance="Transparent"
                               Command="{Binding PreviousMonthCommand}" Padding="8"/>
                    <TextBlock Text="{Binding PeriodLabel}" FontSize="24" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0"
                               FontFamily="{StaticResource MainFont}"/>
                    <ui:Button Icon="{ui:SymbolIcon ChevronRight24}" Appearance="Transparent"
                               Command="{Binding NextMonthCommand}" Padding="8"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <ui:Button Content="{Binding [ImportFile], Source={x:Static svc:Loc.Instance}}"
                               Icon="{ui:SymbolIcon ArrowUpload24}" Appearance="Transparent"
                               Command="{Binding ImportFromFileCommand}" Margin="0,0,8,0"/>
                    <ui:Button Content="{Binding [ExportFinance], Source={x:Static svc:Loc.Instance}}"
                               Icon="{ui:SymbolIcon ArrowDownload24}" Appearance="Transparent"
                               Command="{Binding ExportFinanceCommand}"/>
                </StackPanel>
            </DockPanel>

            <!-- Summary Cards — Row 1: Income, Expenses, Balance, Net Worth -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Income -->
                <Border Grid.Column="0" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [Income], Source={x:Static svc:Loc.Instance}}"
                                   Style="{StaticResource StatLabel}"/>
                        <TextBlock FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}">
                            <Run Text="+"/><Run Text="{Binding TotalIncome, StringFormat=N2, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Expenses -->
                <Border Grid.Column="2" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [Expenses], Source={x:Static svc:Loc.Instance}}"
                                   Style="{StaticResource StatLabel}"/>
                        <TextBlock FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource DangerBrush}">
                            <Run Text="-"/><Run Text="{Binding TotalExpenses, StringFormat=N2, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Balance (Cash Flow) -->
                <Border Grid.Column="4" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [BalanceLabel], Source={x:Static svc:Loc.Instance}}"
                                   Style="{StaticResource StatLabel}"/>
                        <TextBlock Text="{Binding Balance, StringFormat=N2}" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource MutedBrush}">
                            <Run Text="{Binding [Savings], Source={x:Static svc:Loc.Instance}, Mode=OneWay}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding SavingsRatePercent, StringFormat=N1, Mode=OneWay}"/>
                            <Run Text="%" FontWeight="SemiBold"/>
                            <Run Text=" "/><Run Text="{Binding SavingsTrendArrow, Mode=OneWay}" FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Net Worth = Balance + OwedToMe - IOwn -->
                <Border Grid.Column="6" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [NetWorth], Source={x:Static svc:Loc.Instance}}"
                                   Style="{StaticResource StatLabel}"/>
                        <TextBlock Text="{Binding NetWorth, StringFormat=N2}" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource InfoBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Summary Cards — Row 2: Expected Income, Owed to Me, I Owe, Obligatory -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Expected Income (from Income Sources) -->
                <Border Grid.Column="0" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [ExpectedIncome], Source={x:Static svc:Loc.Instance}}"
                                   Style="{StaticResource StatLabel}"/>
                        <TextBlock FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}">
                            <Run Text="{Binding ReceivedIncome, StringFormat=N2, Mode=OneWay}"/>
                            <Run Text=" / " Foreground="{DynamicResource MutedBrush}"/>
                            <Run Text="{Binding ExpectedIncome, StringFormat=N2, Mode=OneWay}" Foreground="{DynamicResource MutedBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Owed to Me -->
                <Border Grid.Column="2" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [DebtLent], Source={x:Static svc:Loc.Instance}}"
                                   Style="{StaticResource StatLabel}"/>
                        <TextBlock FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}">
                            <Run Text="+"/><Run Text="{Binding DebtOwedToMe, StringFormat=N2, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- I Owe -->
                <Border Grid.Column="4" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [DebtBorrowed], Source={x:Static svc:Loc.Instance}}"
                                   Style="{StaticResource StatLabel}"/>
                        <TextBlock FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource DangerBrush}">
                            <Run Text="-"/><Run Text="{Binding DebtIOwn, StringFormat=N2, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Obligatory -->
                <Border Grid.Column="6" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [MonthlyObligatory], Source={x:Static svc:Loc.Instance}}"
                                   Style="{StaticResource StatLabel}"/>
                        <TextBlock Text="{Binding MonthlyObligatory, StringFormat=N2}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Tab Strip (7 tabs) -->
            <Border Style="{StaticResource PlannerCard}" Padding="4" Margin="0,0,0,12">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="{Binding [Income], Source={x:Static svc:Loc.Instance}}"
                                 Style="{StaticResource FinanceTabButton}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={conv:IntEqualConverter}, ConverterParameter=0}"
                                 GroupName="FinanceTab" Checked="TabChanged" Tag="0"/>
                    <RadioButton Content="{Binding [Expenses], Source={x:Static svc:Loc.Instance}}"
                                 Style="{StaticResource FinanceTabButton}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={conv:IntEqualConverter}, ConverterParameter=1}"
                                 GroupName="FinanceTab" Checked="TabChanged" Tag="1"/>
                    <RadioButton Content="{Binding [Debts], Source={x:Static svc:Loc.Instance}}"
                                 Style="{StaticResource FinanceTabButton}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={conv:IntEqualConverter}, ConverterParameter=2}"
                                 GroupName="FinanceTab" Checked="TabChanged" Tag="2"/>
                    <RadioButton Content="{Binding [RecurringPayments], Source={x:Static svc:Loc.Instance}}"
                                 Style="{StaticResource FinanceTabButton}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={conv:IntEqualConverter}, ConverterParameter=3}"
                                 GroupName="FinanceTab" Checked="TabChanged" Tag="3"/>
                    <RadioButton Content="{Binding [FinGoals], Source={x:Static svc:Loc.Instance}}"
                                 Style="{StaticResource FinanceTabButton}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={conv:IntEqualConverter}, ConverterParameter=4}"
                                 GroupName="FinanceTab" Checked="TabChanged" Tag="4"/>
                    <RadioButton Content="{Binding [Accounts], Source={x:Static svc:Loc.Instance}}"
                                 Style="{StaticResource FinanceTabButton}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={conv:IntEqualConverter}, ConverterParameter=5}"
                                 GroupName="FinanceTab" Checked="TabChanged" Tag="5"/>
                    <RadioButton Content="{Binding [IncomeSources], Source={x:Static svc:Loc.Instance}}"
                                 Style="{StaticResource FinanceTabButton}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={conv:IntEqualConverter}, ConverterParameter=6}"
                                 GroupName="FinanceTab" Checked="TabChanged" Tag="6"/>
                    <RadioButton Content="{Binding [Analytics], Source={x:Static svc:Loc.Instance}}"
                                 Style="{StaticResource FinanceTabButton}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={conv:IntEqualConverter}, ConverterParameter=7}"
                                 GroupName="FinanceTab" Checked="TabChanged" Tag="7"/>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═══ Filter Bar (shown on Income/Expenses tabs) ═══ -->
            <Border Style="{StaticResource PlannerCard}" Padding="12,8" Margin="0,0,0,12"
                    Visibility="{Binding SelectedTabIndex, Converter={conv:IntToVisibilityConverter}, ConverterParameter=0}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Search24" FontSize="14" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ui:TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                               PlaceholderText="{Binding [SearchPlaceholder], Source={x:Static svc:Loc.Instance}}"
                               MinWidth="150" FontSize="12" Padding="6,4"/>
                    <TextBlock Text="{Binding [DateFrom], Source={x:Static svc:Loc.Instance}}"
                               FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FilterDateFrom, Converter={conv:NullableDateOnlyToDateTimeConverter}}"
                                Style="{StaticResource CompactDatePicker}"/>
                    <TextBlock Text="{Binding [DateTo], Source={x:Static svc:Loc.Instance}}"
                               FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FilterDateTo, Converter={conv:NullableDateOnlyToDateTimeConverter}}"
                                Style="{StaticResource CompactDatePicker}"/>
                    <ui:Button Content="{Binding [ClearFilter], Source={x:Static svc:Loc.Instance}}"
                               Appearance="Transparent" FontSize="11" Padding="8,3"
                               Command="{Binding ClearFilterCommand}" Margin="12,0,0,0"
                               Visibility="{Binding IsFilterActive, Converter={StaticResource VisConv}}"/>
                </StackPanel>
            </Border>
            <!-- Duplicate filter bar for expenses tab -->
            <Border Style="{StaticResource PlannerCard}" Padding="12,8" Margin="0,0,0,12"
                    Visibility="{Binding SelectedTabIndex, Converter={conv:IntToVisibilityConverter}, ConverterParameter=1}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Search24" FontSize="14" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ui:TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                               PlaceholderText="{Binding [SearchPlaceholder], Source={x:Static svc:Loc.Instance}}"
                               MinWidth="150" FontSize="12" Padding="6,4"/>
                    <TextBlock Text="{Binding [DateFrom], Source={x:Static svc:Loc.Instance}}"
                               FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FilterDateFrom, Converter={conv:NullableDateOnlyToDateTimeConverter}}"
                                Style="{StaticResource CompactDatePicker}"/>
                    <TextBlock Text="{Binding [DateTo], Source={x:Static svc:Loc.Instance}}"
                               FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <DatePicker SelectedDate="{Binding FilterDateTo, Converter={conv:NullableDateOnlyToDateTimeConverter}}"
                                Style="{StaticResource CompactDatePicker}"/>
                    <ui:Button Content="{Binding [ClearFilter], Source={x:Static svc:Loc.Instance}}"
                               Appearance="Transparent" FontSize="11" Padding="8,3"
                               Command="{Binding ClearFilterCommand}" Margin="12,0,0,0"
                               Visibility="{Binding IsFilterActive, Converter={StaticResource VisConv}}"/>
                </StackPanel>
            </Border>

            <!-- ═══════════════ TAB 0: Income ═══════════════ -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={conv:IntToVisibilityConverter}, ConverterParameter=0}">
                <Border Style="{StaticResource PlannerCard}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="ArrowTrendingLines24" FontSize="18"
                                           Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [Income], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding FilteredIncomeEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource InputBgBrush}" CornerRadius="12"
                                            Padding="14,10" Margin="0,0,0,6">
                                        <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding CategoryIcon}" FontSize="20"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                       DockPanel.Dock="Right" Padding="4" VerticalAlignment="Center"
                                                       Command="{Binding DataContext.RemoveIncomeEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"/>
                                            <TextBox DockPanel.Dock="Right"
                                                     Text="{Binding Amount, Converter={StaticResource CurrencyConv}, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource FinanceAmountTextBox}"
                                                     Foreground="{DynamicResource SuccessBrush}"
                                                     VerticalAlignment="Center" Margin="8,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource FinanceInlineTextBox}"/>
                                                <StackPanel Orientation="Horizontal" Margin="4,2,0,0">
                                                    <ComboBox ItemsSource="{Binding DataContext.IncomeCategories, RelativeSource={RelativeSource AncestorType=Page}}"
                                                              SelectedValue="{Binding CategoryId}"
                                                              SelectedValuePath="Id"
                                                              DisplayMemberPath="Name"
                                                              FontSize="11" Padding="4,1" MinWidth="100"
                                                              Background="Transparent" BorderThickness="0"/>
                                                    <DatePicker SelectedDate="{Binding Date, Converter={conv:DateOnlyToDateTimeConverter}}"
                                                                Style="{StaticResource CompactDatePicker}" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DockPanel>
                                        <!-- Split entries -->
                                        <ItemsControl ItemsSource="{Binding SplitEntries}" Margin="32,4,0,0"
                                                      Visibility="{Binding HasSplits, Converter={StaticResource VisConv}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                        <TextBlock Text="├" FontSize="11" Foreground="{DynamicResource MutedBrush}" Margin="0,0,6,0"/>
                                                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource FinanceInlineTextBox}" FontSize="11" MinWidth="80"/>
                                                        <TextBox Text="{Binding Amount, Converter={StaticResource CurrencyConv}, UpdateSourceTrigger=LostFocus}"
                                                                 Style="{StaticResource FinanceInlineTextBox}" FontSize="11" MinWidth="60"
                                                                 TextAlignment="Right" Margin="8,0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ui:Button Content="{Binding [AddSplit], Source={x:Static svc:Loc.Instance}}"
                                                   Appearance="Transparent" FontSize="10" Padding="4,2" Margin="32,2,0,0"
                                                   Command="{Binding DataContext.AddSplitEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,16"
                                   Visibility="{Binding HasFilteredIncome, Converter={StaticResource InvVisConv}}"/>

                        <ui:Button Content="{Binding [AddEntry], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddIncomeEntryCommand}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Income Category Management -->
                <Border Style="{StaticResource PlannerCard}" Padding="16" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding [FinCategories], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding IncomeCategories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox Text="{Binding Icon, UpdateSourceTrigger=LostFocus}"
                                                 FontSize="18" Width="36" TextAlignment="Center"
                                                 Background="Transparent" BorderThickness="0"
                                                 Padding="2" VerticalAlignment="Center"
                                                 ToolTip="{Binding [ChangeIcon], Source={x:Static svc:Loc.Instance}}"/>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource FinanceInlineTextBox}" FontSize="12"
                                                 MinWidth="100" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════ TAB 1: Expenses ═══════════════ -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={conv:IntToVisibilityConverter}, ConverterParameter=1}">
                <!-- Expenses section -->
                <Border Style="{StaticResource PlannerCard}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="DataBarVertical24" FontSize="18"
                                           Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [Expenses], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding FilteredExpenseEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource InputBgBrush}" CornerRadius="12"
                                            Padding="14,10" Margin="0,0,0,6">
                                        <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding CategoryIcon}" FontSize="20"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                       DockPanel.Dock="Right" Padding="4" VerticalAlignment="Center"
                                                       Command="{Binding DataContext.RemoveExpenseEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"/>
                                            <TextBox DockPanel.Dock="Right"
                                                     Text="{Binding Amount, Converter={StaticResource CurrencyConv}, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource FinanceAmountTextBox}"
                                                     Foreground="{DynamicResource DangerBrush}"
                                                     VerticalAlignment="Center" Margin="8,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource FinanceInlineTextBox}"/>
                                                <StackPanel Orientation="Horizontal" Margin="4,2,0,0">
                                                    <ComboBox ItemsSource="{Binding DataContext.ExpenseCategories, RelativeSource={RelativeSource AncestorType=Page}}"
                                                              SelectedValue="{Binding CategoryId}"
                                                              SelectedValuePath="Id"
                                                              DisplayMemberPath="Name"
                                                              FontSize="11" Padding="4,1" MinWidth="100"
                                                              Background="Transparent" BorderThickness="0"/>
                                                    <DatePicker SelectedDate="{Binding Date, Converter={conv:DateOnlyToDateTimeConverter}}"
                                                                Style="{StaticResource CompactDatePicker}" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DockPanel>
                                        <!-- Split entries -->
                                        <ItemsControl ItemsSource="{Binding SplitEntries}" Margin="32,4,0,0"
                                                      Visibility="{Binding HasSplits, Converter={StaticResource VisConv}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                        <TextBlock Text="├" FontSize="11" Foreground="{DynamicResource MutedBrush}" Margin="0,0,6,0"/>
                                                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource FinanceInlineTextBox}" FontSize="11" MinWidth="80"/>
                                                        <TextBox Text="{Binding Amount, Converter={StaticResource CurrencyConv}, UpdateSourceTrigger=LostFocus}"
                                                                 Style="{StaticResource FinanceInlineTextBox}" FontSize="11" MinWidth="60"
                                                                 TextAlignment="Right" Margin="8,0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ui:Button Content="{Binding [AddSplit], Source={x:Static svc:Loc.Instance}}"
                                                   Appearance="Transparent" FontSize="10" Padding="4,2" Margin="32,2,0,0"
                                                   Command="{Binding DataContext.AddSplitEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,16"
                                   Visibility="{Binding HasFilteredExpense, Converter={StaticResource InvVisConv}}"/>

                        <ui:Button Content="{Binding [AddEntry], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddExpenseEntryCommand}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Budgets section -->
                <Border Style="{StaticResource PlannerCard}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="DataPie24" FontSize="18"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [Budget], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Budgets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource InputBgBrush}" CornerRadius="12"
                                            Padding="14,10" Margin="0,0,0,6">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="{Binding CategoryIcon}" FontSize="16"
                                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                           DockPanel.Dock="Right" Padding="4"
                                                           Command="{Binding DataContext.RemoveBudgetCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"/>
                                                <TextBlock Text="{Binding CategoryName}" FontSize="13" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock DockPanel.Dock="Right" FontSize="12"
                                                           Foreground="{DynamicResource MutedBrush}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Run Text="{Binding SpentAmount, StringFormat=N2, Mode=OneWay}"/>
                                                    <Run Text=" / "/>
                                                    <Run Text="{Binding Amount, StringFormat=N2, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DockPanel>
                                            <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100"
                                                         Height="4" Margin="0,8,0,0"
                                                         Foreground="{Binding ProgressPercent, Converter={StaticResource BudgetBrushConv}}"
                                                         Style="{DynamicResource BudgetProgressBar}"/>
                                            <TextBlock Text="{Binding WarningText}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WarningBrush}" Margin="0,4,0,0"
                                                       Visibility="{Binding ShowWarning, Converter={StaticResource VisConv}}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,12"
                                   Visibility="{Binding HasBudgets, Converter={StaticResource InvVisConv}}"/>

                        <ui:Button Content="{Binding [AddBudget], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddBudgetCommand}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Expense Category Management -->
                <Border Style="{StaticResource PlannerCard}" Padding="16" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding [FinCategories], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding ExpenseCategories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox Text="{Binding Icon, UpdateSourceTrigger=LostFocus}"
                                                 FontSize="18" Width="36" TextAlignment="Center"
                                                 Background="Transparent" BorderThickness="0"
                                                 Padding="2" VerticalAlignment="Center"
                                                 ToolTip="{Binding [ChangeIcon], Source={x:Static svc:Loc.Instance}}"/>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource FinanceInlineTextBox}" FontSize="12"
                                                 MinWidth="100" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════ TAB 2: Debts ═══════════════ -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={conv:IntToVisibilityConverter}, ConverterParameter=2}">

                <!-- Debt summary cards -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PlannerCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{Binding [DebtLent], Source={x:Static svc:Loc.Instance}}"
                                       Style="{StaticResource StatLabel}"/>
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}">
                                <Run Text="+"/><Run Text="{Binding DebtOwedToMe, StringFormat=N2, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PlannerCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{Binding [DebtBorrowed], Source={x:Static svc:Loc.Instance}}"
                                       Style="{StaticResource StatLabel}"/>
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}">
                                <Run Text="-"/><Run Text="{Binding DebtIOwn, StringFormat=N2, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Lent debts -->
                <Border Style="{StaticResource PlannerCard}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="ArrowForward16" FontSize="18"
                                           Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [DebtLent], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding LentDebts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource InputBgBrush}" CornerRadius="12"
                                            Padding="16,14" Margin="0,0,0,8">
                                        <StackPanel>
                                            <DockPanel>
                                                <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                           DockPanel.Dock="Right" Padding="4" VerticalAlignment="Top"
                                                           Command="{Binding DataContext.RemoveDebtCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"/>
                                                <TextBox DockPanel.Dock="Right"
                                                         Text="{Binding Amount, Converter={StaticResource CurrencyConv}, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource FinanceAmountTextBox}"
                                                         Foreground="{DynamicResource SuccessBrush}"
                                                         VerticalAlignment="Top" Margin="8,0"/>
                                                <StackPanel>
                                                    <TextBox Text="{Binding PersonName, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource FinanceInlineTextBox}"
                                                             FontSize="15" FontWeight="SemiBold"/>
                                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource FinanceInlineTextBox}"
                                                             FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                                                    <!-- DueDate picker -->
                                                    <StackPanel Orientation="Horizontal" Margin="4,4,0,0">
                                                        <TextBlock Text="{Binding [DueDate], Source={x:Static svc:Loc.Instance}}"
                                                                   FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <DatePicker SelectedDate="{Binding DueDate, Converter={conv:NullableDateOnlyToDateTimeConverter}}"
                                                                    Style="{StaticResource CompactDatePicker}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DockPanel>
                                            <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100"
                                                         Height="4" Margin="0,10,0,6"
                                                         Style="{DynamicResource AccentProgressBar}"/>
                                            <DockPanel>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center">
                                                    <Run Text="{Binding [FinRemaining], Source={x:Static svc:Loc.Instance}, Mode=OneWay}"/>
                                                    <Run Text=": "/>
                                                    <Run Text="{Binding RemainingAmount, StringFormat=N2, Mode=OneWay}" FontWeight="SemiBold"/>
                                                </TextBlock>
                                                <ui:Button Content="{Binding [AddPayment], Source={x:Static svc:Loc.Instance}}"
                                                           Icon="{ui:SymbolIcon Add24}"
                                                           Appearance="Transparent" FontSize="11" Padding="8,3"
                                                           HorizontalAlignment="Right"
                                                           Command="{Binding DataContext.AddDebtPaymentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,8"
                                   Visibility="{Binding HasLentDebts, Converter={StaticResource InvVisConv}}"/>

                        <ui:Button Content="{Binding [AddDebt], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddDebtCommand}" CommandParameter="Lent"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Borrowed debts -->
                <Border Style="{StaticResource PlannerCard}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="18"
                                           Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [DebtBorrowed], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding BorrowedDebts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource InputBgBrush}" CornerRadius="12"
                                            Padding="16,14" Margin="0,0,0,8">
                                        <StackPanel>
                                            <DockPanel>
                                                <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                           DockPanel.Dock="Right" Padding="4" VerticalAlignment="Top"
                                                           Command="{Binding DataContext.RemoveDebtCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"/>
                                                <TextBox DockPanel.Dock="Right"
                                                         Text="{Binding Amount, Converter={StaticResource CurrencyConv}, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource FinanceAmountTextBox}"
                                                         Foreground="{DynamicResource DangerBrush}"
                                                         VerticalAlignment="Top" Margin="8,0"/>
                                                <StackPanel>
                                                    <TextBox Text="{Binding PersonName, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource FinanceInlineTextBox}"
                                                             FontSize="15" FontWeight="SemiBold"/>
                                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource FinanceInlineTextBox}"
                                                             FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                                                    <!-- DueDate picker -->
                                                    <StackPanel Orientation="Horizontal" Margin="4,4,0,0">
                                                        <TextBlock Text="{Binding [DueDate], Source={x:Static svc:Loc.Instance}}"
                                                                   FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <DatePicker SelectedDate="{Binding DueDate, Converter={conv:NullableDateOnlyToDateTimeConverter}}"
                                                                    Style="{StaticResource CompactDatePicker}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DockPanel>
                                            <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100"
                                                         Height="4" Margin="0,10,0,6"
                                                         Style="{DynamicResource AccentProgressBar}"/>
                                            <DockPanel>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center">
                                                    <Run Text="{Binding [FinRemaining], Source={x:Static svc:Loc.Instance}, Mode=OneWay}"/>
                                                    <Run Text=": "/>
                                                    <Run Text="{Binding RemainingAmount, StringFormat=N2, Mode=OneWay}" FontWeight="SemiBold"/>
                                                </TextBlock>
                                                <ui:Button Content="{Binding [AddPayment], Source={x:Static svc:Loc.Instance}}"
                                                           Icon="{ui:SymbolIcon Add24}"
                                                           Appearance="Transparent" FontSize="11" Padding="8,3"
                                                           HorizontalAlignment="Right"
                                                           Command="{Binding DataContext.AddDebtPaymentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,8"
                                   Visibility="{Binding HasBorrowedDebts, Converter={StaticResource InvVisConv}}"/>

                        <ui:Button Content="{Binding [AddDebt], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddDebtCommand}" CommandParameter="Borrowed"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════ TAB 3: Recurring Payments ═══════════════ -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={conv:IntToVisibilityConverter}, ConverterParameter=3}">
                <Border Style="{StaticResource PlannerCard}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="ArrowRepeatAll24" FontSize="18"
                                           Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [RecurringPayments], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding RecurringPayments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource InputBgBrush}" CornerRadius="12"
                                            Padding="16,12" Margin="0,0,0,8">
                                        <DockPanel>
                                            <TextBlock Text="{Binding CategoryIcon}" FontSize="22"
                                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                       DockPanel.Dock="Right" Padding="4" VerticalAlignment="Center"
                                                       Command="{Binding DataContext.RemoveRecurringPaymentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"/>
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource FinanceInlineTextBox}"
                                                             FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBox DockPanel.Dock="Right"
                                                             Text="{Binding Amount, Converter={StaticResource CurrencyConv}, UpdateSourceTrigger=LostFocus}"
                                                             Style="{StaticResource FinanceAmountTextBox}"
                                                             Foreground="{Binding Type, Converter={StaticResource TypeBrushConv}}"
                                                             VerticalAlignment="Center" Margin="8,0"/>
                                                </DockPanel>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource MutedBrush}" Margin="4,4,0,0">
                                                    <Run Text="{Binding FrequencyLabel, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding ScheduleLabel, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding CategoryName, Mode=OneWay}"/>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="4,2,0,0">
                                                    <TextBlock FontSize="10" Foreground="{DynamicResource InfoBrush}"
                                                               Text="{Binding NextPaymentDate, Mode=OneWay}"
                                                               Margin="0,0,12,0"/>
                                                    <TextBlock FontSize="10" Foreground="{DynamicResource MutedBrush}">
                                                        <Run Text="{Binding [AnnualTotal], Source={x:Static svc:Loc.Instance}, Mode=OneWay}"/>
                                                        <Run Text=": "/>
                                                        <Run Text="{Binding AnnualTotal, StringFormat=N0, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Border Background="{DynamicResource SubtleBgBrush}" CornerRadius="8" Padding="8,3" Margin="0,0,8,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <CheckBox IsChecked="{Binding IsActive}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding [Active], Source={x:Static svc:Loc.Instance}}"
                                                                       FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Background="{DynamicResource SubtleBgBrush}" CornerRadius="8" Padding="8,3">
                                                        <StackPanel Orientation="Horizontal">
                                                            <CheckBox IsChecked="{Binding AutoCreate}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding [Auto], Source={x:Static svc:Loc.Instance}}"
                                                                       FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,12"
                                   Visibility="{Binding HasRecurringPayments, Converter={StaticResource InvVisConv}}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <ui:Button Content="{Binding [AddRecurring], Source={x:Static svc:Loc.Instance}}"
                                       Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                       Command="{Binding AddRecurringPaymentCommand}" CommandParameter="Expense"
                                       Margin="0,0,8,0"/>
                            <ui:Button Content="{Binding [Income], Source={x:Static svc:Loc.Instance}}"
                                       Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                       Command="{Binding AddRecurringPaymentCommand}" CommandParameter="Income"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════ TAB 4: Financial Goals ═══════════════ -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={conv:IntToVisibilityConverter}, ConverterParameter=4}">
                <Border Style="{StaticResource PlannerCard}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="🎯" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [FinGoals], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding FinancialGoals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource InputBgBrush}" CornerRadius="12"
                                            Padding="16,14" Margin="0,0,0,8">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="{Binding Icon}" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                           DockPanel.Dock="Right" Padding="4" VerticalAlignment="Top"
                                                           Command="{Binding DataContext.RemoveFinancialGoalCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"/>
                                                <StackPanel>
                                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource FinanceInlineTextBox}"
                                                             FontSize="15" FontWeight="SemiBold"/>
                                                    <Grid Margin="0,6,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding [TargetAmount], Source={x:Static svc:Loc.Instance}}"
                                                                       FontSize="10" Foreground="{DynamicResource MutedBrush}"/>
                                                            <TextBox Text="{Binding TargetAmount, Converter={StaticResource CurrencyConv}, UpdateSourceTrigger=LostFocus}"
                                                                     Style="{StaticResource FinanceInlineTextBox}" FontSize="13" MinWidth="80"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="{Binding [SavedAmount], Source={x:Static svc:Loc.Instance}}"
                                                                       FontSize="10" Foreground="{DynamicResource MutedBrush}"/>
                                                            <TextBox Text="{Binding SavedAmount, Converter={StaticResource CurrencyConv}, UpdateSourceTrigger=LostFocus}"
                                                                     Style="{StaticResource FinanceInlineTextBox}" FontSize="13" MinWidth="80"
                                                                     Foreground="{DynamicResource SuccessBrush}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="4">
                                                            <TextBlock Text="{Binding [TargetDate], Source={x:Static svc:Loc.Instance}}"
                                                                       FontSize="10" Foreground="{DynamicResource MutedBrush}"/>
                                                            <DatePicker SelectedDate="{Binding TargetDate, Converter={conv:NullableDateOnlyToDateTimeConverter}}"
                                                                        Style="{StaticResource CompactDatePicker}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </DockPanel>
                                            <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100"
                                                         Height="6" Margin="0,10,0,4"
                                                         Style="{DynamicResource AccentProgressBar}"/>
                                            <DockPanel>
                                                <TextBlock Text="{Binding ProgressText}" FontSize="11"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                           FontSize="11" Foreground="{DynamicResource MutedBrush}">
                                                    <Run Text="{Binding [FinRemaining], Source={x:Static svc:Loc.Instance}, Mode=OneWay}"/>
                                                    <Run Text=": "/>
                                                    <Run Text="{Binding RemainingAmount, StringFormat=N2, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoFinGoals], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,12"
                                   Visibility="{Binding HasFinancialGoals, Converter={StaticResource InvVisConv}}"/>

                        <ui:Button Content="{Binding [AddFinGoal], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddFinancialGoalCommand}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════ TAB 5: Accounts ═══════════════ -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={conv:IntToVisibilityConverter}, ConverterParameter=5}">
                <!-- Account cards -->
                <Border Style="{StaticResource PlannerCard}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="💳" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [Accounts], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Accounts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource InputBgBrush}" CornerRadius="12"
                                            Padding="16,12" Margin="0,0,0,8">
                                        <DockPanel>
                                            <TextBlock Text="{Binding Icon}" FontSize="24" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                       DockPanel.Dock="Right" Padding="4" VerticalAlignment="Center"
                                                       Command="{Binding DataContext.RemoveAccountCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"/>
                                            <StackPanel>
                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource FinanceInlineTextBox}"
                                                         FontSize="15" FontWeight="SemiBold"/>
                                                <TextBlock FontSize="22" FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentBrush}" Margin="4,4,0,0">
                                                    <Run Text="{Binding CurrentBalance, StringFormat=N2, Mode=OneWay}"/>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="4,4,0,0">
                                                    <TextBlock Text="{Binding [InitialBalance], Source={x:Static svc:Loc.Instance}}"
                                                               FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBox Text="{Binding InitialBalance, Converter={StaticResource CurrencyConv}, UpdateSourceTrigger=LostFocus}"
                                                             Style="{StaticResource FinanceInlineTextBox}" FontSize="11" MinWidth="80"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoAccounts], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,12"
                                   Visibility="{Binding HasAccounts, Converter={StaticResource InvVisConv}}"/>

                        <ui:Button Content="{Binding [AddAccount], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddAccountCommand}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Transfers -->
                <Border Style="{StaticResource PlannerCard}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="18"
                                           Foreground="{DynamicResource InfoBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [Transfer], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Transfers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource InputBgBrush}" CornerRadius="12"
                                            Padding="14,10" Margin="0,0,0,6">
                                        <DockPanel>
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                       DockPanel.Dock="Right" Padding="4" VerticalAlignment="Center"
                                                       Command="{Binding DataContext.RemoveTransferCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"/>
                                            <TextBox DockPanel.Dock="Right"
                                                     Text="{Binding Amount, Converter={StaticResource CurrencyConv}, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource FinanceAmountTextBox}"
                                                     Foreground="{DynamicResource InfoBrush}"
                                                     VerticalAlignment="Center" Margin="8,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontSize="13">
                                                    <Run Text="{Binding FromIcon, Mode=OneWay}"/>
                                                    <Run Text="{Binding FromAccountName, Mode=OneWay}"/>
                                                    <Run Text=" → "/>
                                                    <Run Text="{Binding ToIcon, Mode=OneWay}"/>
                                                    <Run Text="{Binding ToAccountName, Mode=OneWay}"/>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <DatePicker SelectedDate="{Binding Date, Converter={conv:DateOnlyToDateTimeConverter}}"
                                                                Style="{StaticResource CompactDatePicker}"/>
                                                    <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource FinanceInlineTextBox}" FontSize="11"
                                                             Foreground="{DynamicResource MutedBrush}" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,12"
                                   Visibility="{Binding HasTransfers, Converter={StaticResource InvVisConv}}"/>

                        <ui:Button Content="{Binding [AddTransfer], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddTransferCommand}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════ TAB 6: Income Sources ═══════════════ -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={conv:IntToVisibilityConverter}, ConverterParameter=6}">

                <!-- Add Source Button -->
                <ui:Button Content="{Binding [AddSource], Source={x:Static svc:Loc.Instance}}"
                           Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                           Command="{Binding AddIncomeSourceCommand}" Margin="0,0,0,12"/>

                <!-- Empty state -->
                <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                           Foreground="{DynamicResource MutedBrush}" FontSize="13"
                           Visibility="{Binding HasIncomeSources, Converter={StaticResource InvVisConv}}"
                           Margin="0,0,0,12"/>

                <!-- Income Source cards -->
                <ItemsControl ItemsSource="{Binding IncomeSources}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource PlannerCard}" Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <!-- Header: icon + name + client + total + remove -->
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Icon}" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent" Padding="4"
                                                   Command="{Binding DataContext.RemoveIncomeSourceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}" DockPanel.Dock="Right" VerticalAlignment="Center"/>
                                        <StackPanel>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FinanceInlineTextBox}"
                                                     ToolTip="{Binding [ProjectName], Source={x:Static svc:Loc.Instance}}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBox Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource FinanceInlineTextBox}" MinWidth="120"
                                                         ToolTip="{Binding [ClientName], Source={x:Static svc:Loc.Instance}}"/>
                                                <TextBlock Text="{Binding [TotalMonthly], Source={x:Static svc:Loc.Instance}}"
                                                           Foreground="{DynamicResource MutedBrush}" FontSize="11"
                                                           VerticalAlignment="Center" Margin="12,0,4,0"/>
                                                <TextBox Text="{Binding TotalMonthlyAmount, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource FinanceAmountTextBox}" MinWidth="100"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Payment schedule header -->
                                    <DockPanel Margin="0,4,0,6">
                                        <TextBlock Text="{Binding [PaymentSchedule], Source={x:Static svc:Loc.Instance}}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                                        <ui:Button Content="{Binding [AddPaymentDate], Source={x:Static svc:Loc.Instance}}"
                                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent" Padding="4,2"
                                                   FontSize="11" Command="{Binding AddPaymentCommand}"
                                                   HorizontalAlignment="Right"/>
                                    </DockPanel>

                                    <!-- Payment rows -->
                                    <ItemsControl ItemsSource="{Binding Payments}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource SubtleBgBrush}"
                                                        CornerRadius="8" Padding="10,6" Margin="0,0,0,4">
                                                    <DockPanel>
                                                        <ui:Button Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent" Padding="2"
                                                                   Command="{Binding DataContext.RemovePaymentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=2}}"
                                                                   CommandParameter="{Binding}" DockPanel.Dock="Right"
                                                                   VerticalAlignment="Center"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding [PaymentDay], Source={x:Static svc:Loc.Instance}}"
                                                                       FontSize="11" Foreground="{DynamicResource MutedBrush}"
                                                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                            <TextBox Text="{Binding DayOfMonth, UpdateSourceTrigger=LostFocus}"
                                                                     Style="{StaticResource FinanceInlineTextBox}" MinWidth="35" MaxWidth="40"/>
                                                            <TextBox Text="{Binding Amount, UpdateSourceTrigger=LostFocus}"
                                                                     Style="{StaticResource FinanceAmountTextBox}" MinWidth="90" Margin="10,0,0,0"/>
                                                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{StaticResource FinanceInlineTextBox}" MinWidth="120" Margin="10,0,0,0"
                                                                     ToolTip="..."/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Scheduled total -->
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                                Visibility="{Binding HasPayments, Converter={StaticResource VisConv}}">
                                        <TextBlock Text="{Binding [Scheduled], Source={x:Static svc:Loc.Instance}}"
                                                   FontSize="11" Foreground="{DynamicResource MutedBrush}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding ScheduledTotal, StringFormat=N2}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Monthly status: Expected vs Received per source -->
                <Border Style="{StaticResource PlannerCard}" Padding="16" Margin="0,0,0,12"
                        Visibility="{Binding HasIncomeSourceStatuses, Converter={StaticResource VisConv}}">
                    <StackPanel>
                        <TextBlock Text="{Binding [PaymentSchedule], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding IncomeSourceStatuses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <DockPanel>
                                            <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center">
                                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                                <Run Text=" — " Foreground="{DynamicResource MutedBrush}"/>
                                                <Run Text="{Binding Received, StringFormat=N2, Mode=OneWay}" Foreground="{DynamicResource SuccessBrush}"/>
                                                <Run Text=" / " Foreground="{DynamicResource MutedBrush}"/>
                                                <Run Text="{Binding Expected, StringFormat=N2, Mode=OneWay}"/>
                                            </TextBlock>
                                        </DockPanel>
                                        <!-- Progress bar -->
                                        <ProgressBar Height="4" Margin="0,4,0,0" Minimum="0" Maximum="100"
                                                     Value="{Binding ProgressPercent, Mode=OneWay}"
                                                     Foreground="{DynamicResource SuccessBrush}"
                                                     Background="{DynamicResource SubtleBgBrush}"/>
                                        <!-- Individual payments -->
                                        <ItemsControl ItemsSource="{Binding Payments}" Margin="0,4,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="8" Padding="6,2" Margin="0,0,6,4"
                                                            Background="{DynamicResource SubtleBgBrush}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock FontSize="11">
                                                                <Run Text="{Binding DisplayDate, Mode=OneWay}"/>
                                                                <Run Text=" — "/>
                                                                <Run Text="{Binding Amount, StringFormat=N0, Mode=OneWay}"/>
                                                            </TextBlock>
                                                            <TextBlock Text=" ✓" FontSize="11" FontWeight="Bold"
                                                                       Foreground="{DynamicResource SuccessBrush}"
                                                                       Visibility="{Binding IsPaid, Converter={StaticResource VisConv}}"/>
                                                            <TextBlock Text=" ⏳" FontSize="11"
                                                                       Visibility="{Binding IsPaid, Converter={StaticResource InvVisConv}}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════ TAB 7: Analytics ═══════════════ -->
            <StackPanel Visibility="{Binding SelectedTabIndex, Converter={conv:IntToVisibilityConverter}, ConverterParameter=7}">

                <!-- Balance Forecast -->
                <Border Style="{StaticResource PlannerCard}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="ArrowTrendingLines24" FontSize="18"
                                           Foreground="{DynamicResource InfoBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [ForecastBalance], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="12,0,0,0"
                                       Text="{Binding [ForecastDays], Source={x:Static svc:Loc.Instance}}"/>
                        </StackPanel>

                        <!-- Forecast summary -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding [ProjectedIncome], Source={x:Static svc:Loc.Instance}}"
                                           FontSize="10" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ProjectedIncome, StringFormat=N2}" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding [ProjectedExpenses], Source={x:Static svc:Loc.Instance}}"
                                           FontSize="10" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ProjectedExpenses, StringFormat=N2}" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding [Forecast], Source={x:Static svc:Loc.Instance}}"
                                           FontSize="10" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ForecastBalance, StringFormat=N2}" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Forecast bar chart -->
                        <ItemsControl ItemsSource="{Binding ForecastDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="1,0" ToolTip="{Binding Balance, StringFormat=N2}">
                                        <Border Height="3" CornerRadius="1"
                                                Background="{DynamicResource AccentBrush}" Opacity="0.5"
                                                VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Cashflow Calendar -->
                <Border Style="{StaticResource PlannerCard}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="18"
                                           Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [CashflowCalendar], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding CashflowDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="42" Height="48" Margin="2" CornerRadius="8"
                                            Background="{DynamicResource InputBgBrush}"
                                            ToolTip="{Binding Net, StringFormat=N2}">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding DayLabel}" FontSize="12" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Ellipse Width="5" Height="5" Margin="1"
                                                         Fill="{DynamicResource SuccessBrush}"
                                                         Visibility="{Binding Income, Converter={conv:DecimalToVisibilityConverter}}"/>
                                                <Ellipse Width="5" Height="5" Margin="1"
                                                         Fill="{DynamicResource DangerBrush}"
                                                         Visibility="{Binding Expenses, Converter={conv:DecimalToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Category Breakdown -->
                <Border Style="{StaticResource PlannerCard}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="DataPie24" FontSize="18"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [FinCategories], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding CategoryBreakdown}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock FontSize="13" VerticalAlignment="Center">
                                                <Run Text="{Binding Icon, Mode=OneWay}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock DockPanel.Dock="Right" FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource DangerBrush}">
                                                <Run Text="{Binding Amount, StringFormat=N2, Mode=OneWay}"/>
                                            </TextBlock>
                                        </DockPanel>
                                        <Border Background="{DynamicResource ProgressTrackBrush}" CornerRadius="3" Height="8">
                                            <Border CornerRadius="3" HorizontalAlignment="Left"
                                                    Height="8" MinWidth="4">
                                                <Border.Background>
                                                    <Binding Path="Color" Converter="{conv:StringToBrushConverter}" FallbackValue="#cba6f7"/>
                                                </Border.Background>
                                                <Border.Width>
                                                    <MultiBinding Converter="{conv:CategoryBarWidthConverter}">
                                                        <Binding Path="Amount"/>
                                                        <Binding Path="DataContext.TotalExpenses"
                                                                 RelativeSource="{RelativeSource AncestorType=Page}"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                            </Border>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,12"
                                   Visibility="{Binding HasCategoryBreakdown, Converter={StaticResource InvVisConv}}"/>
                    </StackPanel>
                </Border>

                <!-- 6-Month Trend -->
                <Border Style="{StaticResource PlannerCard}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="ArrowTrendingLines24" FontSize="18"
                                           Foreground="{DynamicResource InfoBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [MonthlyTrend], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding MonthlyTrend}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="{Binding DataContext.MonthlyTrendCount, RelativeSource={RelativeSource AncestorType=Page}}" Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,0">
                                        <Border Background="{DynamicResource SuccessBrush}" CornerRadius="4,4,0,0"
                                                Height="{Binding Income, Converter={conv:TrendBarHeightConverter}}"
                                                VerticalAlignment="Bottom" Opacity="0.7"
                                                ToolTip="{Binding Income, StringFormat=N2}"/>
                                        <Border Background="{DynamicResource DangerBrush}" CornerRadius="0,0,4,4"
                                                Height="{Binding Expenses, Converter={conv:TrendBarHeightConverter}}"
                                                VerticalAlignment="Top" Opacity="0.7"
                                                ToolTip="{Binding Expenses, StringFormat=N2}"
                                                Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding Label}" FontSize="10"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                        <TextBlock FontSize="10" Foreground="{DynamicResource AccentLightBrush}"
                                                   HorizontalAlignment="Center">
                                            <Run Text="{Binding Balance, StringFormat=N0, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,12"
                                   Visibility="{Binding HasMonthlyTrend, Converter={StaticResource InvVisConv}}"/>
                    </StackPanel>
                </Border>

                <!-- Savings Rate Card -->
                <Border Style="{StaticResource PlannerCard}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:SymbolIcon Symbol="DataBarVertical24" FontSize="18"
                                           Foreground="{DynamicResource InfoBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding [SavingsRate], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource InfoBrush}" VerticalAlignment="Center">
                                <Run Text="{Binding SavingsRatePercent, StringFormat=N1, Mode=OneWay}"/><Run Text="%"/>
                            </TextBlock>
                            <ProgressBar Value="{Binding SavingsRatePercent, Mode=OneWay}" Maximum="100"
                                         Height="10" Margin="0,0,20,0"
                                         Style="{DynamicResource AccentProgressBar}"/>
                        </DockPanel>
                        <TextBlock FontSize="11" Foreground="{DynamicResource MutedBrush}" Margin="0,8,0,0">
                            <Run Text="{Binding [Savings], Source={x:Static svc:Loc.Instance}, Mode=OneWay}"/>
                            <Run Text=": "/>
                            <Run Text="{Binding Savings, StringFormat=N2, Mode=OneWay}" FontWeight="SemiBold"/>
                            <Run Text=" "/>
                            <Run Text="{Binding SavingsTrendArrow, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

    <!-- Loading overlay -->
    <Border Background="#B3000000" CornerRadius="12"
            Visibility="{Binding IsLoading, Converter={StaticResource VisConv}}"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Padding="28,18">
        <StackPanel Orientation="Horizontal">
            <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20"/>
            <TextBlock Text="{Binding [Loading], Source={x:Static svc:Loc.Instance}}"
                       FontSize="13" Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
    </Grid>
</Page>
