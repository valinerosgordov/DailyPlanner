<Page x:Class="DailyPlanner.Views.FinancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:conv="clr-namespace:DailyPlanner.Converters"
      xmlns:svc="clr-namespace:DailyPlanner.Services"
      Foreground="{DynamicResource TextPrimaryBrush}">

    <Page.Resources>
        <conv:FinanceTypeToBrushConverter x:Key="TypeBrushConv"/>
        <conv:BudgetProgressToBrushConverter x:Key="BudgetBrushConv"/>
        <conv:DecimalToCurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="VisConv"/>
        <conv:InvertedBoolToVisibilityConverter x:Key="InvVisConv"/>
    </Page.Resources>

    <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,0,24,24" MaxWidth="960" HorizontalAlignment="Left">

            <!-- Header with month navigation -->
            <DockPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ui:Button Icon="{ui:SymbolIcon ChevronLeft24}" Appearance="Transparent"
                               Command="{Binding PreviousMonthCommand}" Padding="8"/>
                    <TextBlock Text="{Binding PeriodLabel}" FontSize="24" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0"
                               FontFamily="{StaticResource MainFont}"/>
                    <ui:Button Icon="{ui:SymbolIcon ChevronRight24}" Appearance="Transparent"
                               Command="{Binding NextMonthCommand}" Padding="8"/>
                </StackPanel>
            </DockPanel>

            <!-- Summary Cards -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Income -->
                <Border Grid.Column="0" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{Binding [Income], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock FontSize="22" FontWeight="Bold"
                                   Foreground="#34D399">
                            <Run Text="+"/><Run Text="{Binding TotalIncome, StringFormat=N2, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Expenses -->
                <Border Grid.Column="2" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{Binding [Expenses], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock FontSize="22" FontWeight="Bold"
                                   Foreground="#FB7185">
                            <Run Text="-"/><Run Text="{Binding TotalExpenses, StringFormat=N2, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Balance -->
                <Border Grid.Column="4" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{Binding [BalanceLabel], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="{Binding Balance, StringFormat=N2}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Obligatory -->
                <Border Grid.Column="6" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{Binding [MonthlyObligatory], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="{Binding MonthlyObligatory, StringFormat=N2}" FontSize="22" FontWeight="Bold"
                                   Foreground="#FBBF24"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Tab Control -->
            <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                        Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="16,8"/>
                    </Style>
                </TabControl.Resources>

                <!-- TAB: Income -->
                <TabItem Header="{Binding [Income], Source={x:Static svc:Loc.Instance}}">
                    <StackPanel Margin="0,16,0,0">
                        <ItemsControl ItemsSource="{Binding IncomeEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PlannerCard}" Padding="12,10" Margin="0,0,0,6">
                                        <DockPanel>
                                            <TextBlock Text="{Binding CategoryIcon}" FontSize="18"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                       DockPanel.Dock="Right" Padding="4"
                                                       Command="{Binding DataContext.RemoveIncomeEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"/>
                                            <TextBlock DockPanel.Dock="Right" FontSize="18" FontWeight="SemiBold"
                                                       Foreground="#34D399" VerticalAlignment="Center" Margin="12,0">
                                                <Run Text="+"/><Run Text="{Binding Amount, StringFormat=N2, Mode=OneWay}"/>
                                            </TextBlock>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="13" Background="Transparent" BorderThickness="0"
                                                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="10" Foreground="{DynamicResource MutedBrush}">
                                                    <Run Text="{Binding CategoryName, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding DisplayDate, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,12"
                                   Visibility="{Binding IncomeEntries.Count, Converter={StaticResource InvVisConv}}"/>

                        <ui:Button Content="{Binding [AddEntry], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddIncomeEntryCommand}" Margin="0,8,0,0"/>
                    </StackPanel>
                </TabItem>

                <!-- TAB: Expenses -->
                <TabItem Header="{Binding [Expenses], Source={x:Static svc:Loc.Instance}}">
                    <StackPanel Margin="0,16,0,0">
                        <ItemsControl ItemsSource="{Binding ExpenseEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PlannerCard}" Padding="12,10" Margin="0,0,0,6">
                                        <DockPanel>
                                            <TextBlock Text="{Binding CategoryIcon}" FontSize="18"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                       DockPanel.Dock="Right" Padding="4"
                                                       Command="{Binding DataContext.RemoveExpenseEntryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"/>
                                            <TextBlock DockPanel.Dock="Right" FontSize="18" FontWeight="SemiBold"
                                                       Foreground="#FB7185" VerticalAlignment="Center" Margin="12,0">
                                                <Run Text="-"/><Run Text="{Binding Amount, StringFormat=N2, Mode=OneWay}"/>
                                            </TextBlock>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="13" Background="Transparent" BorderThickness="0"
                                                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="10" Foreground="{DynamicResource MutedBrush}">
                                                    <Run Text="{Binding CategoryName, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding DisplayDate, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ui:Button Content="{Binding [AddEntry], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddExpenseEntryCommand}" Margin="0,8,0,0"/>

                        <!-- Budgets section -->
                        <TextBlock Text="{Binding [Budget], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,24,0,10"/>

                        <ItemsControl ItemsSource="{Binding Budgets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PlannerCard}" Padding="12,10" Margin="0,0,0,6">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="{Binding CategoryIcon}" FontSize="14" Margin="0,0,8,0"/>
                                                <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                           DockPanel.Dock="Right" Padding="4"
                                                           Command="{Binding DataContext.RemoveBudgetCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"/>
                                                <TextBlock Text="{Binding CategoryName}" FontSize="13" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock DockPanel.Dock="Right" FontSize="12"
                                                           Foreground="{DynamicResource MutedBrush}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Run Text="{Binding SpentAmount, StringFormat=N2, Mode=OneWay}"/>
                                                    <Run Text=" / "/>
                                                    <Run Text="{Binding Amount, StringFormat=N2, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DockPanel>
                                            <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                                                         Height="4" Margin="0,6,0,0"
                                                         Foreground="{Binding ProgressPercent, Converter={StaticResource BudgetBrushConv}}"
                                                         Style="{StaticResource DayProgressBar}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,8"
                                   Visibility="{Binding Budgets.Count, Converter={StaticResource InvVisConv}}"/>

                        <ui:Button Content="{Binding [AddBudget], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddBudgetCommand}" Margin="0,4,0,0"/>
                    </StackPanel>
                </TabItem>

                <!-- TAB: Debts -->
                <TabItem Header="{Binding [Debts], Source={x:Static svc:Loc.Instance}}">
                    <StackPanel Margin="0,16,0,0">

                        <!-- Debt summary -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource PlannerCard}" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="{Binding [DebtLent], Source={x:Static svc:Loc.Instance}}"
                                               FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#34D399">
                                        <Run Text="+"/><Run Text="{Binding DebtOwedToMe, StringFormat=N2, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource PlannerCard}" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="{Binding [DebtBorrowed], Source={x:Static svc:Loc.Instance}}"
                                               FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#FB7185">
                                        <Run Text="-"/><Run Text="{Binding DebtIOwn, StringFormat=N2, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Lent debts -->
                        <TextBlock Text="{Binding [DebtLent], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <ItemsControl ItemsSource="{Binding LentDebts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PlannerCard}" Padding="14,12" Margin="0,0,0,8">
                                        <StackPanel>
                                            <DockPanel>
                                                <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                           DockPanel.Dock="Right" Padding="4"
                                                           Command="{Binding DataContext.RemoveDebtCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"/>
                                                <StackPanel>
                                                    <TextBox Text="{Binding PersonName, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="15" FontWeight="SemiBold"
                                                             Background="Transparent" BorderThickness="0"
                                                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="11" Background="Transparent" BorderThickness="0"
                                                             Foreground="{DynamicResource MutedBrush}"/>
                                                </StackPanel>
                                                <TextBlock DockPanel.Dock="Right" FontSize="18" FontWeight="Bold"
                                                           Foreground="#34D399" VerticalAlignment="Top" Margin="8,0">
                                                    <Run Text="{Binding Amount, StringFormat=N2, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DockPanel>
                                            <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                                                         Height="4" Margin="0,8,0,4"
                                                         Style="{StaticResource DayProgressBar}"/>
                                            <DockPanel>
                                                <TextBlock FontSize="10" Foreground="{DynamicResource MutedBrush}">
                                                    <Run Text="{Binding [Remaining], Source={x:Static svc:Loc.Instance}, Mode=OneWay}"/>
                                                    <Run Text=": "/>
                                                    <Run Text="{Binding RemainingAmount, StringFormat=N2, Mode=OneWay}"/>
                                                </TextBlock>
                                                <ui:Button Content="{Binding [AddPayment], Source={x:Static svc:Loc.Instance}}"
                                                           Appearance="Transparent" FontSize="10" Padding="6,2"
                                                           HorizontalAlignment="Right"
                                                           Command="{Binding DataContext.AddDebtPaymentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ui:Button Content="{Binding [AddDebt], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddDebtCommand}" CommandParameter="Lent"
                                   Margin="0,4,0,16"/>

                        <!-- Borrowed debts -->
                        <TextBlock Text="{Binding [DebtBorrowed], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <ItemsControl ItemsSource="{Binding BorrowedDebts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PlannerCard}" Padding="14,12" Margin="0,0,0,8">
                                        <StackPanel>
                                            <DockPanel>
                                                <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                           DockPanel.Dock="Right" Padding="4"
                                                           Command="{Binding DataContext.RemoveDebtCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"/>
                                                <StackPanel>
                                                    <TextBox Text="{Binding PersonName, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="15" FontWeight="SemiBold"
                                                             Background="Transparent" BorderThickness="0"
                                                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="11" Background="Transparent" BorderThickness="0"
                                                             Foreground="{DynamicResource MutedBrush}"/>
                                                </StackPanel>
                                                <TextBlock DockPanel.Dock="Right" FontSize="18" FontWeight="Bold"
                                                           Foreground="#FB7185" VerticalAlignment="Top" Margin="8,0">
                                                    <Run Text="{Binding Amount, StringFormat=N2, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DockPanel>
                                            <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                                                         Height="4" Margin="0,8,0,4"
                                                         Style="{StaticResource DayProgressBar}"/>
                                            <DockPanel>
                                                <TextBlock FontSize="10" Foreground="{DynamicResource MutedBrush}">
                                                    <Run Text="{Binding [Remaining], Source={x:Static svc:Loc.Instance}, Mode=OneWay}"/>
                                                    <Run Text=": "/>
                                                    <Run Text="{Binding RemainingAmount, StringFormat=N2, Mode=OneWay}"/>
                                                </TextBlock>
                                                <ui:Button Content="{Binding [AddPayment], Source={x:Static svc:Loc.Instance}}"
                                                           Appearance="Transparent" FontSize="10" Padding="6,2"
                                                           HorizontalAlignment="Right"
                                                           Command="{Binding DataContext.AddDebtPaymentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding}"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ui:Button Content="{Binding [AddDebt], Source={x:Static svc:Loc.Instance}}"
                                   Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                   Command="{Binding AddDebtCommand}" CommandParameter="Borrowed"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </TabItem>

                <!-- TAB: Recurring Payments -->
                <TabItem Header="{Binding [RecurringPayments], Source={x:Static svc:Loc.Instance}}">
                    <StackPanel Margin="0,16,0,0">

                        <ItemsControl ItemsSource="{Binding RecurringPayments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PlannerCard}" Padding="14,12" Margin="0,0,0,8">
                                        <DockPanel>
                                            <TextBlock Text="{Binding CategoryIcon}" FontSize="18"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                       DockPanel.Dock="Right" Padding="4"
                                                       Command="{Binding DataContext.RemoveRecurringPaymentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"/>
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             FontSize="14" FontWeight="SemiBold"
                                                             Background="Transparent" BorderThickness="0"
                                                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock DockPanel.Dock="Right" FontSize="16" FontWeight="Bold"
                                                               VerticalAlignment="Center" HorizontalAlignment="Right"
                                                               Text="{Binding DisplayAmount}"
                                                               Foreground="{Binding Type, Converter={StaticResource TypeBrushConv}}"/>
                                                </DockPanel>
                                                <TextBlock FontSize="10" Foreground="{DynamicResource MutedBrush}" Margin="2,2,0,0">
                                                    <Run Text="{Binding FrequencyLabel, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding ScheduleLabel, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding CategoryName, Mode=OneWay}"/>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <CheckBox IsChecked="{Binding IsActive}" Content="{Binding [Auto], Source={x:Static svc:Loc.Instance}}"
                                                              FontSize="10" Margin="0,0,12,0"/>
                                                    <CheckBox IsChecked="{Binding AutoCreate}" Content="{Binding [Remind], Source={x:Static svc:Loc.Instance}}"
                                                              FontSize="10"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding [NoEntries], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,8"
                                   Visibility="{Binding RecurringPayments.Count, Converter={StaticResource InvVisConv}}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <ui:Button Content="{Binding [AddRecurring], Source={x:Static svc:Loc.Instance}}"
                                       Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                       Command="{Binding AddRecurringPaymentCommand}" CommandParameter="Expense"
                                       Margin="0,0,8,0"/>
                            <ui:Button Content="{Binding [Income], Source={x:Static svc:Loc.Instance}}"
                                       Icon="{ui:SymbolIcon Add24}" Appearance="Transparent"
                                       Command="{Binding AddRecurringPaymentCommand}" CommandParameter="Income"/>
                        </StackPanel>
                    </StackPanel>
                </TabItem>
            </TabControl>

        </StackPanel>
    </ScrollViewer>

    <!-- Loading overlay -->
    <Border Background="#80000000" CornerRadius="8"
            Visibility="{Binding IsLoading, Converter={StaticResource VisConv}}"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Padding="24,16">
        <StackPanel Orientation="Horizontal">
            <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20"/>
            <TextBlock Text="{Binding [Loading], Source={x:Static svc:Loc.Instance}}"
                       FontSize="13" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
    </Grid>
</Page>
