<Window x:Class="DailyPlanner.Views.WeeklyReviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:svc="clr-namespace:DailyPlanner.Services"
        Title="{Binding [WeeklyReview], Source={x:Static svc:Loc.Instance}}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="560" SizeToContent="Height" MaxHeight="640"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Border CornerRadius="12" Padding="24,20"
            Background="#F0101014"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.55" Color="Black"/>
        </Border.Effect>

        <StackPanel>
            <!-- Header -->
            <DockPanel Margin="0,0,0,18">
                <TextBlock DockPanel.Dock="Left" FontSize="22" FontWeight="Bold"
                           Text="{Binding [WeeklyReview], Source={x:Static svc:Loc.Instance}}"
                           Foreground="{DynamicResource AccentBrush}"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding WeekLabel}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedBrush}" FontSize="13"
                           HorizontalAlignment="Right"/>
            </DockPanel>

            <!-- Top row: tasks / completion / best day -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [Completed], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding CompletedTasks}" FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}"/>
                            <TextBlock Text=" / " FontSize="24" Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock Text="{Binding TotalTasks}" FontSize="24"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [ProgressLabel], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="{Binding CompletionRate, StringFormat={}{0}%}" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [BestDay], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="{Binding BestDayName}" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding BestDayCount, StringFormat={}{0} ✓}" FontSize="11"
                                   Foreground="{DynamicResource MutedBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Second row: goals / habits -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [WeekGoals], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding GoalsReached}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}"/>
                            <TextBlock Text=" / " FontSize="22" Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock Text="{Binding TotalGoals}" FontSize="22"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PlannerCard}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [Habits], Source={x:Static svc:Loc.Instance}}"
                                   FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding HabitsCompleted}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}"/>
                            <TextBlock Text=" / " FontSize="22" Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock Text="{Binding HabitsTotal}" FontSize="22"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Third row: state averages -->
            <Border Style="{StaticResource PlannerCard}" Padding="14" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding [StateSelfReport], Source={x:Static svc:Loc.Instance}}"
                               FontSize="11" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding [Sleep], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="10" Foreground="{DynamicResource MutedBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding AvgSleep, StringFormat={}{0:0.0}}"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource InfoBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding [Energy], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="10" Foreground="{DynamicResource MutedBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding AvgEnergy, StringFormat={}{0:0.0}}"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WarningBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding [Mood], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="10" Foreground="{DynamicResource MutedBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding AvgMood, StringFormat={}{0:0.0}}"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <DockPanel>
                <ui:Button DockPanel.Dock="Right" Content="{Binding [Close], Source={x:Static svc:Loc.Instance}}"
                           Appearance="Primary" Padding="20,8"
                           Click="Close_Click"/>
            </DockPanel>
        </StackPanel>
    </Border>
</Window>
