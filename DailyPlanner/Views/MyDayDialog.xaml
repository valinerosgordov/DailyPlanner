<Window x:Class="DailyPlanner.Views.MyDayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:DailyPlanner.Services"
        Title="{Binding [MyDayTitle], Source={x:Static svc:Loc.Instance}}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Width="480" SizeToContent="Height" MaxHeight="600"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="VisConv"/>
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Padding="24,20"
            Background="{DynamicResource CardBg}"
            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="{Binding GreetingIcon}" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="{Binding Greeting}"
                               FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding TodayDate}" FontSize="12"
                               Foreground="{DynamicResource MutedBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Yesterday's incomplete tasks -->
            <Border CornerRadius="10" Padding="12,10" Margin="0,0,0,12"
                    Visibility="{Binding HasYesterdayTasks, Converter={StaticResource VisConv}}">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.08"/>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="{Binding [MyDayYesterday], Source={x:Static svc:Loc.Instance}}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding YesterdayTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="&#x25CB;" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding}" FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Today's tasks -->
            <Border CornerRadius="10" Padding="12,10" Margin="0,0,0,12">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.05"/>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="{Binding [MyDayToday], Source={x:Static svc:Loc.Instance}}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding TodayTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="{Binding Icon}" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{Binding IconBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Text}" FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding [MyDayNoTasks], Source={x:Static svc:Loc.Instance}}"
                               FontSize="12" Foreground="{DynamicResource MutedBrush}"
                               Visibility="{Binding HasNoTodayTasks, Converter={StaticResource VisConv}}"/>
                </StackPanel>
            </Border>

            <!-- Overdue tasks with deadlines -->
            <Border CornerRadius="10" Padding="12,10" Margin="0,0,0,12"
                    Visibility="{Binding HasOverdueTasks, Converter={StaticResource VisConv}}">
                <Border.Background>
                    <SolidColorBrush Color="#FB7185" Opacity="0.1"/>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="{Binding [MyDayOverdue], Source={x:Static svc:Loc.Instance}}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource DangerBrush}" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding OverdueTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="&#x26A0;" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding}" FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Summary -->
            <TextBlock Text="{Binding Summary}" FontSize="11"
                       Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <!-- Buttons -->
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="{Binding [MyDayStart], Source={x:Static svc:Loc.Instance}}"
                        Padding="20,8" FontWeight="SemiBold" FontSize="13" Cursor="Hand"
                        Click="Start_Click"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <CheckBox Content="{Binding [MyDayDontShow], Source={x:Static svc:Loc.Instance}}"
                          IsChecked="{Binding DontShowAgain}" FontSize="11"
                          Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
            </DockPanel>
        </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
