<Page x:Class="DailyPlanner.Views.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:conv="clr-namespace:DailyPlanner.Converters"
      Foreground="{DynamicResource TextPrimaryBrush}">

    <Page.Resources>
        <conv:HeatmapIntensityToBrushConverter x:Key="HeatConv"/>
        <conv:BoolToVisibilityConverter x:Key="VisConv"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,0,24,24" MaxWidth="900" HorizontalAlignment="Left">

            <!-- Header with navigation -->
            <DockPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ui:Button Icon="{ui:SymbolIcon ChevronLeft24}" Appearance="Transparent"
                               Command="{Binding PreviousMonthCommand}" Padding="8"/>
                    <TextBlock Text="{Binding PeriodLabel}" FontSize="24" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0"
                               FontFamily="{StaticResource MainFont}"/>
                    <ui:Button Icon="{ui:SymbolIcon ChevronRight24}" Appearance="Transparent"
                               Command="{Binding NextMonthCommand}" Padding="8"/>
                </StackPanel>
            </DockPanel>

            <!-- Stat Cards Row 1 -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Всего задач" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="{Binding MonthTotalTasks}" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Выполнено" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="{Binding MonthCompletedTasks}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Продуктивность" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}">
                            <Run Text="{Binding MonthCompletionRate, StringFormat={}{0}%, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Лучший день" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="{Binding MostProductiveDay}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Stat Cards Row 2 -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Цели" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold">
                            <Run Text="{Binding MonthCompletedGoals, Mode=OneWay}"/>/<Run Text="{Binding MonthTotalGoals, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Ср. сон" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="{Binding AvgSleep, StringFormat={}{0:F1}}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource InfoBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Ср. энергия" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="{Binding AvgEnergy, StringFormat={}{0:F1}}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource PlannerCard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Ср. настроение" FontSize="11" Foreground="{DynamicResource MutedBrush}"/>
                        <TextBlock Text="{Binding AvgMood, StringFormat={}{0:F1}}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Week Comparison -->
            <Border Style="{StaticResource PlannerCard}" Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="ArrowTrendingLines24" FontSize="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Сравнение недель" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Прошлая неделя" FontSize="11" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="24" FontWeight="Bold" HorizontalAlignment="Center">
                                <Run Text="{Binding PreviousWeekCompleted, Mode=OneWay}"/>/<Run Text="{Binding PreviousWeekTasks, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Тренд" FontSize="11" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding WeekTrend}" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Текущая неделя" FontSize="11" Foreground="{DynamicResource MutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="24" FontWeight="Bold" HorizontalAlignment="Center">
                                <Run Text="{Binding CurrentWeekCompleted, Mode=OneWay}"/>/<Run Text="{Binding CurrentWeekTasks, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Weekly Progress Bars -->
            <Border Style="{StaticResource PlannerCard}" Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="DataBarVertical24" FontSize="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Продуктивность по неделям" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding WeeklyBars}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,3">
                                    <TextBlock Text="{Binding Label}" Width="50" FontSize="11"
                                               Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right" Width="50" FontSize="11" TextAlignment="Right"
                                               Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center">
                                        <Run Text="{Binding Completed, Mode=OneWay}"/>/<Run Text="{Binding Total, Mode=OneWay}"/>
                                    </TextBlock>
                                    <Border Height="18" CornerRadius="4" Margin="8,0"
                                            Background="{DynamicResource ProgressTrackBrush}">
                                        <Border CornerRadius="4" HorizontalAlignment="Left"
                                                Width="{Binding CompletionPercent}"
                                                MaxWidth="300">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                                    <GradientStop Color="{DynamicResource SuccessColor}" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Border>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Habit Heatmap -->
            <Border Style="{StaticResource PlannerCard}" Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="Grid24" FontSize="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Привычки — Heatmap (30 дней)" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding HeatmapData}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="22" Height="22" Margin="2" CornerRadius="4"
                                        Background="{Binding Intensity, Converter={StaticResource HeatConv}}"
                                        ToolTip="{Binding DateLabel}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Habit Streaks -->
            <Border Style="{StaticResource PlannerCard}" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="Fire24" FontSize="18" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Серии привычек" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding Streaks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,4">
                                    <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"/>
                                    <Border DockPanel.Dock="Right" HorizontalAlignment="Right"
                                            Background="{DynamicResource KeyboardShortcutBg}" CornerRadius="8" Padding="10,4">
                                        <TextBlock Text="{Binding StreakText}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WarningBrush}"/>
                                    </Border>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
