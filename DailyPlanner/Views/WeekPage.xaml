<Page x:Class="DailyPlanner.Views.WeekPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:views="clr-namespace:DailyPlanner.Views"
      xmlns:conv="clr-namespace:DailyPlanner.Converters"
      xmlns:svc="clr-namespace:DailyPlanner.Services"
      xmlns:vm="clr-namespace:DailyPlanner.ViewModels"
      Foreground="{DynamicResource TextPrimaryBrush}">

    <Page.Resources>
        <conv:BoolToStrikethroughConverter x:Key="StrikethroughConv"/>
        <conv:BoolToOpacityConverter x:Key="OpacityConv"/>
        <conv:BoolToVisibilityConverter x:Key="VisConv"/>
        <conv:PriorityToBrushConverter x:Key="PriorityBrush"/>

        <conv:CategoryToBrushConverter x:Key="CatBrush"/>
        <conv:CategoryToLabelConverter x:Key="CatLabel"/>
        <conv:NonZeroToVisibilityConverter x:Key="NonZeroVis"/>
        <conv:PriorityToTooltipConverter x:Key="PriorityTip"/>
        <conv:CategoryToTooltipConverter x:Key="CatTip"/>
        <conv:DeadlineToBrushConverter x:Key="DeadlineBrush"/>
        <conv:DeadlineToTextConverter x:Key="DeadlineText"/>
        <conv:NullableToVisibilityConverter x:Key="NullVis"/>
        <conv:InvertedBoolToVisibilityConverter x:Key="InvVisConv"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8,0,8,24" DataContext="{Binding SelectedWeek}">

            <!-- STAT CARDS with tooltips -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total -->
                <Border Style="{StaticResource PlannerCard}" Grid.Column="0" Padding="18" ToolTip="{Binding [TotalTasksTip], Source={x:Static svc:Loc.Instance}}">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="44" Height="44" CornerRadius="12" Margin="0,0,14,0">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.12"/>
                            </Border.Background>
                            <ui:SymbolIcon Symbol="TaskListLtr24" FontSize="20" Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalTasks}" Style="{StaticResource StatValue}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding [TotalTasks], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Completed -->
                <Border Style="{StaticResource PlannerCard}" Grid.Column="2" Padding="18" ToolTip="{Binding [CompletedTip], Source={x:Static svc:Loc.Instance}}">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="44" Height="44" CornerRadius="12" Margin="0,0,14,0">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource SuccessColor}" Opacity="0.12"/>
                            </Border.Background>
                            <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="20" Foreground="{DynamicResource SuccessBrush}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CompletedTasks}" Style="{StaticResource StatValue}"
                                       Foreground="{DynamicResource SuccessBrush}"/>
                            <TextBlock Text="{Binding [CompletedLabel], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Not completed -->
                <Border Style="{StaticResource PlannerCard}" Grid.Column="4" Padding="18" ToolTip="{Binding [NotCompletedTip], Source={x:Static svc:Loc.Instance}}">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="44" Height="44" CornerRadius="12" Margin="0,0,14,0">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource DangerColor}" Opacity="0.12"/>
                            </Border.Background>
                            <ui:SymbolIcon Symbol="DismissCircle24" FontSize="20" Foreground="{DynamicResource DangerBrush}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding NotCompletedTasks}" Style="{StaticResource StatValue}"
                                       Foreground="{DynamicResource DangerBrush}"/>
                            <TextBlock Text="{Binding [NotCompleted], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Goals -->
                <Border Style="{StaticResource PlannerCard}" Grid.Column="6" Padding="18" ToolTip="{Binding [GoalsTip], Source={x:Static svc:Loc.Instance}}">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="44" Height="44" CornerRadius="12" Margin="0,0,14,0">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource WarningColor}" Opacity="0.12"/>
                            </Border.Background>
                            <ui:SymbolIcon Symbol="Star24" FontSize="20" Foreground="{DynamicResource WarningBrush}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource StatValue}" Foreground="{DynamicResource WarningBrush}">
                                <Run Text="{Binding CompletedGoals, Mode=OneWay}"/>/<Run Text="{Binding Goals.Count, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding [GoalsReached], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- WEEKLY SUMMARY -->
            <Border Style="{StaticResource PlannerCard}" Margin="0,0,0,20" Padding="14,10">
                <DockPanel>
                    <ui:SymbolIcon Symbol="Lightbulb24" FontSize="15" Foreground="{DynamicResource WarningBrush}"
                                   DockPanel.Dock="Left" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding WeeklySummary}" FontSize="12"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                </DockPanel>
            </Border>

            <!-- GOALS + NOTES + DONUT -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Goals -->
                <Border Grid.Column="0" Style="{StaticResource PlannerCard}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <ui:SymbolIcon Symbol="Star24" FontSize="15" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding [WeekGoals], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource SectionHeader}" Margin="0"/>
                            </StackPanel>
                            <Button Style="{StaticResource SmallIconButton}" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right" ToolTip="{Binding [AddGoalTip], Source={x:Static svc:Loc.Instance}}"
                                    Command="{Binding AddGoalCommand}">
                                <ui:SymbolIcon Symbol="Add16" FontSize="14"/>
                            </Button>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding Goals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Order, StringFormat='{}{0}.'}"
                                                   Foreground="{DynamicResource MutedBrush}" FontSize="12"
                                                   VerticalAlignment="Center" Width="22" Margin="0,0,4,0"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource PlannerCheckBox}"
                                                  IsChecked="{Binding IsCompleted}" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="2" Style="{StaticResource TaskTextBox}"
                                                 Text="{Binding Text, UpdateSourceTrigger=LostFocus}"
                                                 TextDecorations="{Binding IsCompleted, Converter={StaticResource StrikethroughConv}}"
                                                 Opacity="{Binding IsCompleted, Converter={StaticResource OpacityConv}}"/>
                                        <Button Grid.Column="3" Style="{StaticResource SmallIconButton}"
                                                VerticalAlignment="Center" Margin="4,0,0,0"
                                                Command="{Binding DataContext.RemoveGoalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" ToolTip="{Binding [DeleteTip], Source={x:Static svc:Loc.Instance}}">
                                            <ui:SymbolIcon Symbol="Delete16" FontSize="12"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Notes -->
                <Border Grid.Column="2" Style="{StaticResource PlannerCard}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <ui:SymbolIcon Symbol="Note24" FontSize="15" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding [Notes], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource SectionHeader}" Margin="0"/>
                            </StackPanel>
                            <Button Style="{StaticResource SmallIconButton}" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right" ToolTip="{Binding [AddNoteTip], Source={x:Static svc:Loc.Instance}}"
                                    Command="{Binding AddNoteCommand}">
                                <ui:SymbolIcon Symbol="Add16" FontSize="14"/>
                            </Button>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding WeeklyNotes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Style="{StaticResource NotesTextBox}"
                                                 Text="{Binding Text, UpdateSourceTrigger=LostFocus}"
                                                 MinHeight="50"/>
                                        <Button Grid.Column="1" Style="{StaticResource SmallIconButton}"
                                                VerticalAlignment="Top" Margin="4,0,0,0"
                                                Command="{Binding DataContext.RemoveNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" ToolTip="{Binding [DeleteTip], Source={x:Static svc:Loc.Instance}}">
                                            <ui:SymbolIcon Symbol="Delete16" FontSize="12"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Donut Chart -->
                <Border Grid.Column="4" Style="{StaticResource GlowCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="DataPie24" FontSize="15" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [Progress], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource SectionHeader}" Margin="0"/>
                        </StackPanel>

                        <views:DonutChart Width="140" Height="140" Margin="0,8"
                                          Value="{Binding AverageProgress}"
                                          Maximum="100" RingThickness="10"
                                          TrackBrush="{DynamicResource ProgressTrackBrush}"
                                          ValueBrush="{DynamicResource AccentBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          CenterText="{Binding AverageProgress, StringFormat='{}{0}%'}"
                                          SubText="{Binding [ProgressLabel], Source={x:Static svc:Loc.Instance}}"/>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding MostProductiveDay}" Foreground="{DynamicResource WarningBrush}"
                                           FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding [BestDay], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" FontSize="14"
                                           HorizontalAlignment="Center">
                                    <Run Text="{Binding CompletedGoals, Mode=OneWay}"/>/<Run Text="{Binding Goals.Count, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding [GoalsLabel], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- MEETINGS -->
            <Border Style="{StaticResource PlannerCard}" Margin="0,0,0,20">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <ui:SymbolIcon Symbol="People24" FontSize="15" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [Meetings], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource SectionHeader}" Margin="0"/>
                        </StackPanel>
                        <Button Style="{StaticResource SmallIconButton}" DockPanel.Dock="Right"
                                HorizontalAlignment="Right"
                                ToolTip="{Binding [NewMeeting], Source={x:Static svc:Loc.Instance}}"
                                Command="{Binding DataContext.AddMeetingCommand, RelativeSource={RelativeSource AncestorType=Page}}">
                            <ui:SymbolIcon Symbol="Add16" FontSize="14"/>
                        </Button>
                    </DockPanel>

                    <!-- Empty state -->
                    <TextBlock Text="{Binding [MeetingNoMeetings], Source={x:Static svc:Loc.Instance}}" FontSize="11"
                               Foreground="{DynamicResource MutedBrush}" FontStyle="Italic"
                               HorizontalAlignment="Center" Margin="0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.Meetings.Count, RelativeSource={RelativeSource AncestorType=Page}}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Meeting cards in horizontal wrap -->
                    <ItemsControl ItemsSource="{Binding DataContext.Meetings, RelativeSource={RelativeSource AncestorType=Page}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="12,10" Margin="0,0,10,8" Width="320"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <!-- Title + Delete -->
                                        <DockPanel Margin="0,0,0,6">
                                            <Button DockPanel.Dock="Right" Style="{StaticResource SmallIconButton}"
                                                    Command="{Binding DataContext.RemoveMeetingCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}" VerticalAlignment="Top">
                                                <ui:SymbolIcon Symbol="Delete16" FontSize="12"/>
                                            </Button>
                                            <TextBox Style="{StaticResource TaskTextBox}"
                                                     Text="{Binding Title, UpdateSourceTrigger=LostFocus}"
                                                     FontSize="13" FontWeight="SemiBold"/>
                                        </DockPanel>

                                        <!-- Date & Time & Duration -->
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <DatePicker Grid.Column="0" SelectedDate="{Binding MeetingDate}"
                                                        FontSize="11" VerticalAlignment="Center"/>

                                            <!-- Time picker: HH:MM -->
                                            <Border Grid.Column="1" CornerRadius="8" Padding="6,4" Margin="6,0"
                                                    Background="{DynamicResource InputBgBrush}" VerticalAlignment="Center"
                                                    ToolTip="{Binding [MeetingTime], Source={x:Static svc:Loc.Instance}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding SelectedHour, StringFormat=D2, UpdateSourceTrigger=LostFocus}"
                                                             Width="24" FontSize="12" FontFamily="Cascadia Code, Consolas"
                                                             Background="Transparent" BorderThickness="0" Padding="0"
                                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                                             HorizontalContentAlignment="Center" MaxLength="2"/>
                                                    <TextBlock Text=":" FontSize="12" FontWeight="Bold"
                                                               VerticalAlignment="Center" Margin="1,0"
                                                               Foreground="{DynamicResource MutedBrush}"/>
                                                    <TextBox Text="{Binding SelectedMinute, StringFormat=D2, UpdateSourceTrigger=LostFocus}"
                                                             Width="24" FontSize="12" FontFamily="Cascadia Code, Consolas"
                                                             Background="Transparent" BorderThickness="0" Padding="0"
                                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                                             HorizontalContentAlignment="Center" MaxLength="2"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Duration -->
                                            <Border Grid.Column="2" CornerRadius="8" Padding="6,4"
                                                    Background="{DynamicResource InputBgBrush}" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding DurationMinutes, UpdateSourceTrigger=LostFocus}"
                                                             Width="30" FontSize="12" FontFamily="Cascadia Code, Consolas"
                                                             Background="Transparent" BorderThickness="0" Padding="0"
                                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                                             HorizontalContentAlignment="Center" MaxLength="3"/>
                                                    <TextBlock Text="{Binding [MeetingMin], Source={x:Static svc:Loc.Instance}}"
                                                               FontSize="9" Foreground="{DynamicResource MutedBrush}"
                                                               VerticalAlignment="Center" Margin="2,0,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Attendees -->
                                        <DockPanel Margin="0,0,0,4">
                                            <ui:SymbolIcon Symbol="People16" FontSize="11"
                                                           Foreground="{DynamicResource MutedBrush}"
                                                           DockPanel.Dock="Left" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                            <TextBox Style="{StaticResource TaskTextBox}"
                                                     Text="{Binding Attendees, UpdateSourceTrigger=LostFocus}"
                                                     FontSize="11"
                                                     ToolTip="{Binding [MeetingAttendees], Source={x:Static svc:Loc.Instance}}"/>
                                        </DockPanel>

                                        <!-- Description -->
                                        <TextBox Style="{StaticResource TaskTextBox}"
                                                 Text="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                                 FontSize="10" Foreground="{DynamicResource MutedBrush}"
                                                 TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="50"
                                                 ToolTip="{Binding [MeetingDesc], Source={x:Static svc:Loc.Instance}}"
                                                 Margin="0,0,0,6"/>

                                        <!-- Notification toggles -->
                                        <WrapPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                                <CheckBox IsChecked="{Binding NotifyDayBefore}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                <TextBlock Text="{Binding [MeetingNotifyDay], Source={x:Static svc:Loc.Instance}}"
                                                           FontSize="9" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                                <CheckBox IsChecked="{Binding NotifyTwoHoursBefore}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                <TextBlock Text="{Binding [MeetingNotify2h], Source={x:Static svc:Loc.Instance}}"
                                                           FontSize="9" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox IsChecked="{Binding Notify30MinBefore}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                <TextBlock Text="{Binding [MeetingNotify30m], Source={x:Static svc:Loc.Instance}}"
                                                           FontSize="9" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- DAYS + INBOX SIDEBAR -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="15" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding [WeekTasks], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource SectionHeader}" Margin="0"/>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Inbox sidebar: drag cards from here onto any day column -->
                <Border Grid.Column="0" Style="{StaticResource PlannerCard}" Padding="12"
                        Margin="0,0,12,0" VerticalAlignment="Stretch"
                        DataContext="{Binding DataContext.Inbox, RelativeSource={RelativeSource AncestorType=Page}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="{Binding [InboxTitle], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Icon="{ui:SymbolIcon ArrowSync24}"
                                       Content="{Binding [SyncTrello], Source={x:Static svc:Loc.Instance}}"
                                       Command="{Binding SyncTrelloCommand}"
                                       Appearance="Primary" HorizontalAlignment="Stretch"
                                       FontSize="11" Padding="6,4"/>
                            <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Add24}"
                                       Command="{Binding AddManualCommand}"
                                       Appearance="Secondary" Margin="6,0,0,0"
                                       FontSize="11" Padding="6,4"/>
                        </Grid>

                        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" FontSize="10"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Margin="0,0,0,6" TextWrapping="Wrap"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource VisConv}}"/>

                        <Grid Grid.Row="3">
                            <TextBlock Text="{Binding [InboxEmpty], Source={x:Static svc:Loc.Instance}}"
                                       FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       TextAlignment="Center" TextWrapping="Wrap"
                                       Visibility="{Binding HasTasks, Converter={StaticResource InvVisConv}}"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding HasTasks, Converter={StaticResource VisConv}}">
                                <ItemsControl ItemsSource="{Binding Tasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:InboxTaskViewModel}">
                                            <Border Margin="0,0,0,6" Padding="8,6"
                                                    Background="{DynamicResource CardBg}"
                                                    BorderBrush="{DynamicResource GlassBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Cursor="Hand"
                                                    PreviewMouseLeftButtonDown="InboxItem_MouseDown"
                                                    MouseMove="InboxItem_MouseMove"
                                                    Tag="{Binding}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Text}" FontSize="12"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding SourceLabel}" FontSize="9"
                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                               Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>

                <ItemsControl Grid.Column="1" ItemsSource="{Binding Days}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3,0" Padding="8,12">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource PlannerCard}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="{DynamicResource AccentColor}"
                                                                      BlurRadius="18" ShadowDepth="0" Opacity="0.22"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="{Binding DateFormatted}" DockPanel.Dock="Right"
                                               Foreground="{DynamicResource MutedBrush}"
                                               FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DayName}" Style="{StaticResource DayHeader}" FontSize="12"/>
                                        <!-- Today badge -->
                                        <Border CornerRadius="8" Padding="6,1" Margin="6,0,0,0"
                                                Visibility="{Binding IsToday, Converter={StaticResource VisConv}}">
                                            <Border.Background>
                                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.2"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding [TodayBadge], Source={x:Static svc:Loc.Instance}}" FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentLightBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </DockPanel>

                                <!-- Day progress bar -->
                                <ProgressBar Style="{StaticResource DayProgressBar}"
                                             Value="{Binding ProgressPercent, Mode=OneWay}"
                                             Maximum="100" Margin="0,0,0,8"/>

                                <ItemsControl ItemsSource="{Binding Tasks}" AllowDrop="True"
                                              Tag="{Binding}"
                                              DragOver="Day_DragOver" Drop="Day_Drop">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <!-- Parent task row -->
                                                <Grid Margin="0,1"
                                                      PreviewMouseLeftButtonDown="Task_PreviewMouseLeftButtonDown"
                                                      PreviewMouseMove="Task_PreviewMouseMove">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Priority indicator — wider hit target -->
                                                    <Border Grid.Column="0" Width="6" Height="16" CornerRadius="3" Margin="0,0,4,0"
                                                            Background="{Binding Priority, Converter={StaticResource PriorityBrush}}"
                                                            Visibility="{Binding Priority, Converter={StaticResource NonZeroVis}}"
                                                            ToolTip="{Binding Priority, Converter={StaticResource PriorityTip}}" Cursor="Hand"
                                                            MouseLeftButtonDown="PriorityCycle_Click"/>
                                                    <!-- Expand/collapse toggle -->
                                                    <Border Grid.Column="1" Width="22" Height="22" Cursor="Hand"
                                                            MouseLeftButtonDown="ToggleExpand_Click"
                                                            Background="Transparent" VerticalAlignment="Center"
                                                            Visibility="{Binding HasSubTasks, Converter={StaticResource VisConv}}">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="7"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource MutedBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="&#xE76C;"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                            <Setter Property="Text" Value="&#xE70D;"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <CheckBox Grid.Column="2" Style="{StaticResource PlannerCheckBox}"
                                                              IsChecked="{Binding IsCompleted}" Margin="0,0,3,0"
                                                              VerticalAlignment="Center"/>
                                                    <!-- Category icon -->
                                                    <TextBlock Grid.Column="3" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                               Text="{Binding Category, Converter={StaticResource CatLabel}}"
                                                               Foreground="{Binding Category, Converter={StaticResource CatBrush}}"
                                                               Visibility="{Binding Category, Converter={StaticResource NonZeroVis}}"
                                                               VerticalAlignment="Center" Margin="0,0,2,0"
                                                               ToolTip="{Binding Category, Converter={StaticResource CatTip}}" Cursor="Hand"
                                                               MouseLeftButtonDown="CategoryCycle_Click"/>
                                                    <TextBox Grid.Column="4" Style="{StaticResource TaskTextBox}"
                                                             Text="{Binding Text, UpdateSourceTrigger=LostFocus}"
                                                             TextDecorations="{Binding IsCompleted, Converter={StaticResource StrikethroughConv}}"
                                                             Opacity="{Binding IsCompleted, Converter={StaticResource OpacityConv}}"
                                                             FontSize="11" ToolTip="{Binding Text}">
                                                        <TextBox.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="{Binding [CtxAddSub], Source={x:Static svc:Loc.Instance}}"
                                                                          Click="AddSubTask_Click"/>
                                                                <MenuItem Header="{Binding [CtxDuplicate], Source={x:Static svc:Loc.Instance}}"
                                                                          Click="DuplicateTask_Click"/>
                                                                <MenuItem Header="{Binding [CtxMoveNext], Source={x:Static svc:Loc.Instance}}"
                                                                          Click="MoveTaskNextDay_Click"/>
                                                                <Separator/>
                                                                <MenuItem Header="{Binding [CtxPriority], Source={x:Static svc:Loc.Instance}}">
                                                                    <MenuItem Header="{Binding [PriorityHigh], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxPriorityHigh_Click"/>
                                                                    <MenuItem Header="{Binding [PriorityMedium], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxPriorityMedium_Click"/>
                                                                    <MenuItem Header="{Binding [PriorityLow], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxPriorityLow_Click"/>
                                                                    <MenuItem Header="{Binding [CtxNone], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxPriorityNone_Click"/>
                                                                </MenuItem>
                                                                <MenuItem Header="{Binding [CtxCategory], Source={x:Static svc:Loc.Instance}}">
                                                                    <MenuItem Header="{Binding [CatWork], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxCatWork_Click"/>
                                                                    <MenuItem Header="{Binding [CatStudy], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxCatStudy_Click"/>
                                                                    <MenuItem Header="{Binding [CatPersonal], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxCatPersonal_Click"/>
                                                                    <MenuItem Header="{Binding [CatHealth], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxCatHealth_Click"/>
                                                                    <MenuItem Header="{Binding [CtxNone], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxCatNone_Click"/>
                                                                </MenuItem>
                                                                <MenuItem Header="{Binding [CtxDeadline], Source={x:Static svc:Loc.Instance}}">
                                                                    <MenuItem Header="{Binding [CtxDeadlineToday], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxDeadlineToday_Click"/>
                                                                    <MenuItem Header="{Binding [CtxDeadlineTomorrow], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxDeadlineTomorrow_Click"/>
                                                                    <MenuItem Header="{Binding [CtxDeadlineNextWeek], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxDeadlineNextWeek_Click"/>
                                                                    <MenuItem Header="{Binding [CtxDeadlineClear], Source={x:Static svc:Loc.Instance}}"
                                                                              Click="CtxDeadlineClear_Click"/>
                                                                </MenuItem>
                                                                <Separator/>
                                                                <MenuItem Header="{Binding [CtxDelete], Source={x:Static svc:Loc.Instance}}"
                                                                          Click="DeleteTask_Click"
                                                                          Foreground="{DynamicResource DangerBrush}"/>
                                                            </ContextMenu>
                                                        </TextBox.ContextMenu>
                                                    </TextBox>
                                                    <!-- Deadline badge -->
                                                    <TextBlock Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               Margin="0,0,2,0" FontSize="8" Padding="3,1"
                                                               Text="{Binding Deadline, Converter={StaticResource DeadlineText}}"
                                                               Foreground="{Binding Deadline, Converter={StaticResource DeadlineBrush}}"
                                                               Visibility="{Binding Deadline, Converter={StaticResource NullVis}}"
                                                               IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Opacity" Value="0.8"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                                        <Setter Property="Opacity" Value="0"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Task action buttons — overlay on right, Collapsed until hover -->
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                                                                HorizontalAlignment="Right">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <StackPanel.Background>
                                                            <SolidColorBrush Color="#000000" Opacity="0.88"/>
                                                        </StackPanel.Background>
                                                        <Border Width="22" Height="22" Cursor="Hand" Margin="1,0"
                                                                MouseLeftButtonDown="AddSubTask_Click" Background="Transparent"
                                                                ToolTip="{Binding [AddSubTaskTip], Source={x:Static svc:Loc.Instance}}">
                                                            <TextBlock Text="+" FontSize="11" FontWeight="Bold"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource MutedBrush}"/>
                                                        </Border>
                                                        <Border Width="22" Height="22" Cursor="Hand" Margin="1,0"
                                                                MouseLeftButtonDown="MoveTaskNextDay_Click" Background="Transparent"
                                                                ToolTip="{Binding [MoveNextDayTip], Source={x:Static svc:Loc.Instance}}">
                                                            <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource AccentBrush}"/>
                                                        </Border>
                                                        <Border Width="22" Height="22" Cursor="Hand" Margin="1,0"
                                                                MouseLeftButtonDown="DeleteTask_Click" Background="Transparent"
                                                                ToolTip="{Binding [DeleteTaskTip], Source={x:Static svc:Loc.Instance}}">
                                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource DangerBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                                <!-- Subtasks list -->
                                                <ItemsControl ItemsSource="{Binding SubTasks}" Margin="18,0,0,0"
                                                              Visibility="{Binding IsExpanded, Converter={StaticResource VisConv}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Subtask connector line -->
                                                                <TextBlock Grid.Column="0" Text="└" FontSize="9"
                                                                           Foreground="{DynamicResource MutedBrush}"
                                                                           VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                                <CheckBox Grid.Column="1" Style="{StaticResource PlannerCheckBox}"
                                                                          IsChecked="{Binding IsCompleted}" Margin="0,0,4,0"
                                                                          VerticalAlignment="Center"/>
                                                                <TextBox Grid.Column="2" Style="{StaticResource TaskTextBox}"
                                                                         Text="{Binding Text, UpdateSourceTrigger=LostFocus}"
                                                                         TextDecorations="{Binding IsCompleted, Converter={StaticResource StrikethroughConv}}"
                                                                         Opacity="{Binding IsCompleted, Converter={StaticResource OpacityConv}}"
                                                                         FontSize="10.5"/>
                                                                <!-- Remove subtask -->
                                                                <Border Grid.Column="3" Width="22" Height="22" Cursor="Hand"
                                                                        MouseLeftButtonDown="RemoveSubTask_Click"
                                                                        Background="Transparent" VerticalAlignment="Center">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Opacity" Value="0"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                               Foreground="{DynamicResource DangerBrush}"/>
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <!-- Subtask progress indicator -->
                                                <TextBlock Margin="18,0,0,2" FontSize="9"
                                                           Foreground="{DynamicResource MutedBrush}"
                                                           Text="{Binding SubTasksProgress}"
                                                           Visibility="{Binding HasSubTasks, Converter={StaticResource VisConv}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border CornerRadius="8" Padding="10,6" Margin="0,10,0,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.06"/>
                                    </Border.Background>
                                    <DockPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                            <ui:SymbolIcon Symbol="CheckmarkCircle16" FontSize="12"
                                                           Foreground="{DynamicResource SuccessBrush}" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding CompletedCount, Mode=OneWay}" FontSize="11"
                                                       Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <TextBlock DockPanel.Dock="Right" FontSize="11" HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource MutedBrush}">
                                            <Run Text="{Binding NotCompletedCount, Mode=OneWay}"/>
                                            <Run Text="{Binding [Remaining], Source={x:Static svc:Loc.Instance}, Mode=OneWay}"/>
                                        </TextBlock>
                                    </DockPanel>
                                </Border>
                                <!-- Carry-over button -->
                                <Button Style="{StaticResource SmallIconButton}" HorizontalAlignment="Right"
                                        Margin="0,4,0,0" ToolTip="{Binding [CarryOverTip], Source={x:Static svc:Loc.Instance}}"
                                        Click="CarryOver_Click" Tag="{Binding}">
                                    <ui:SymbolIcon Symbol="ArrowForward16" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- HABITS + STATE -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Habits -->
                <Border Grid.Column="0" Style="{StaticResource PlannerCard}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <ui:SymbolIcon Symbol="Ribbon24" FontSize="15" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding [HabitTracker], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource SectionHeader}" Margin="0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SmallIconButton}" ToolTip="{Binding [AddHabitTip], Source={x:Static svc:Loc.Instance}}"
                                        Command="{Binding AddHabitCommand}">
                                    <ui:SymbolIcon Symbol="Add16" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/><ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="28"/><ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="28"/><ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="28"/><ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding [HabitLabel], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource MutedBrush}" FontSize="10" Margin="4,0,0,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding [Mon], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource MutedBrush}" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding [Tue], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource MutedBrush}" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding [Wed], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource MutedBrush}" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{Binding [Thu], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource MutedBrush}" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="{Binding [Fri], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource MutedBrush}" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="{Binding [Sat], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource MutedBrush}" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="7" Text="{Binding [Sun], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource MutedBrush}" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="8" Text="{Binding [ProgressCol], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource MutedBrush}" FontSize="10" HorizontalAlignment="Center"/>
                        </Grid>
                        <!-- Empty state -->
                        <TextBlock Text="{Binding [HabitEmpty], Source={x:Static svc:Loc.Instance}}" FontSize="11"
                                   Foreground="{DynamicResource MutedBrush}" FontStyle="Italic"
                                   HorizontalAlignment="Center" Margin="0,12"
                                   Visibility="{Binding HasNoHabits, Converter={StaticResource VisConv}}"/>
                        <ItemsControl ItemsSource="{Binding Habits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="28"/><ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="28"/><ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="28"/><ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="28"/><ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Style="{StaticResource TaskTextBox}"
                                                 Text="{Binding Name, UpdateSourceTrigger=LostFocus}" FontSize="11.5"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource PlannerCheckBox}" IsChecked="{Binding Entries[0].IsCompleted}" HorizontalAlignment="Center"/>
                                        <CheckBox Grid.Column="2" Style="{StaticResource PlannerCheckBox}" IsChecked="{Binding Entries[1].IsCompleted}" HorizontalAlignment="Center"/>
                                        <CheckBox Grid.Column="3" Style="{StaticResource PlannerCheckBox}" IsChecked="{Binding Entries[2].IsCompleted}" HorizontalAlignment="Center"/>
                                        <CheckBox Grid.Column="4" Style="{StaticResource PlannerCheckBox}" IsChecked="{Binding Entries[3].IsCompleted}" HorizontalAlignment="Center"/>
                                        <CheckBox Grid.Column="5" Style="{StaticResource PlannerCheckBox}" IsChecked="{Binding Entries[4].IsCompleted}" HorizontalAlignment="Center"/>
                                        <CheckBox Grid.Column="6" Style="{StaticResource PlannerCheckBox}" IsChecked="{Binding Entries[5].IsCompleted}" HorizontalAlignment="Center"/>
                                        <CheckBox Grid.Column="7" Style="{StaticResource PlannerCheckBox}" IsChecked="{Binding Entries[6].IsCompleted}" HorizontalAlignment="Center"/>
                                        <ProgressBar Grid.Column="8" Value="{Binding Progress, Mode=OneWay}" Maximum="7"
                                                     Style="{StaticResource AccentProgressBar}" VerticalAlignment="Center" Margin="6,0"/>
                                        <Button Grid.Column="9" Style="{StaticResource SmallIconButton}" ToolTip="{Binding [DeleteTip], Source={x:Static svc:Loc.Instance}}"
                                                Command="{Binding DataContext.RemoveHabitCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <ui:SymbolIcon Symbol="Delete16" FontSize="12"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- State -->
                <Border Grid.Column="2" Style="{StaticResource PlannerCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="HeartPulse24" FontSize="15" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [StateTracker], Source={x:Static svc:Loc.Instance}}" Style="{StaticResource SectionHeader}" Margin="0"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#x1F31C; " FontSize="11"/>
                                <TextBlock Text="{Binding [Sleep], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource InfoBrush}" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#x26A1; " FontSize="11"/>
                                <TextBlock Text="{Binding [Energy], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource WarningBrush}" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#x1F60A; " FontSize="11"/>
                                <TextBlock Text="{Binding [Mood], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource SuccessBrush}" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Days}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="4,3" Margin="0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding ShortDayName}"
                                                       FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <views:RatingControl Grid.Column="1" Value="{Binding Sleep}" MaxValue="5"
                                                                 StarBrush="{DynamicResource InfoBrush}" HorizontalAlignment="Center"/>
                                            <views:RatingControl Grid.Column="2" Value="{Binding Energy}" MaxValue="5"
                                                                 StarBrush="{DynamicResource WarningBrush}" HorizontalAlignment="Center"/>
                                            <views:RatingControl Grid.Column="3" Value="{Binding Mood}" MaxValue="5"
                                                                 StarBrush="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Averages row -->
                        <Border CornerRadius="8" Padding="4,5" Margin="0,8,0,0"
                                Background="{DynamicResource InputBgBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding [StateAvg], Source={x:Static svc:Loc.Instance}}"
                                           FontSize="9" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding AvgSleep, StringFormat='{}{0:0.0}'}"
                                           FontSize="12" FontWeight="Bold" Foreground="{DynamicResource InfoBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding AvgEnergy, StringFormat='{}{0:0.0}'}"
                                           FontSize="12" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding AvgMood, StringFormat='{}{0:0.0}'}"
                                           FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- State insight -->
                        <TextBlock Text="{Binding StateInsight}" FontSize="10" FontStyle="Italic"
                                   Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,0"
                                   TextWrapping="Wrap" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Height="28"/>
        </StackPanel>
    </ScrollViewer>
</Page>
